{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Context Packet Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "task_id",
    "phase_id",
    "source_plan",
    "created_at",
    "generated_at",
    "scope",
    "retrieval_policy",
    "coverage",
    "included_context",
    "execution_decision",
    "validation",
    "validated_under"
  ],
  "properties": {
    "artifact_type": { "const": "ContextPacketArtifact" },
    "schema_version": { "const": "context-packet.schema.v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "phase_id": { "type": "string", "minLength": 1 },
    "source_plan": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" },
    "scope": { "type": "object" },
    "retrieval_policy": { "type": "object" },
    "coverage": { "type": "object" },
    "included_context": { "type": "array" },
    "execution_decision": { "type": "object" },
    "validation": { "type": "object" },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": { "type": "integer", "const": 1 },
        "workflow_contract_version": { "type": "integer", "const": 1 },
        "command_contract_id": { "type": "string", "const": "context-packet.v1" },
        "command_contract_version": { "type": "integer", "const": 1 },
        "artifact_schema": { "type": "string", "const": "context-packet.schema.v1" },
        "config_instruction_version": { "type": "string", "const": "v1" }
      }
    }
  }
}
