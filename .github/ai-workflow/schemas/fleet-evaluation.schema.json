{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FleetEvaluationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "fleet_evaluation_id",
    "created_at",
    "source_report_refs",
    "source_comparison_policy",
    "evidence_handling_policy",
    "sample_window",
    "cross_developer_patterns",
    "main_bundle_change_candidates",
    "diagnostic_signal_aliases",
    "local_only_candidates",
    "human_decision_request",
    "validated_under"
  ],
  "properties": {
    "artifact_type": { "const": "FleetEvaluationReport" },
    "schema_version": { "const": "fleet-evaluation.schema.v1" },
    "fleet_evaluation_id": {
      "type": "string",
      "pattern": "^FLEET-EVAL-[0-9]{8}-[0-9]{6}$"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "source_report_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "report_ref"],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^SRC-[A-Za-z0-9_-]{6,64}$",
            "description": "Stable pseudonymous source ID. Do not use real names or email addresses."
          },
          "report_ref": { "type": "string", "minLength": 1 },
          "repository_hint": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
            "description": "Optional coarse non-identifying stack/project hint, such as swift-ios-app or spring-boot-monolith. Do not use URLs, organization names, repository names, or company names."
          }
        }
      }
    },
    "source_comparison_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Source IDs prove independence and prevent double-counting. They must not be used to rank or score developers.",
      "required": [
        "source_ids_used_for",
        "developer_ranking_allowed",
        "per_source_performance_scoring_allowed"
      ],
      "properties": {
        "source_ids_used_for": { "const": "independence_and_deduplication_only" },
        "developer_ranking_allowed": { "type": "boolean", "const": false },
        "per_source_performance_scoring_allowed": { "type": "boolean", "const": false }
      }
    },
    "evidence_handling_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Fleet artifacts must stay aggregate-safe. They cite structured evidence refs and paraphrase repeated patterns instead of copying raw developer excerpts.",
      "required": [
        "raw_excerpts_allowed",
        "evidence_refs_required",
        "summary_mode",
        "raw_detail_review_path",
        "raw_detail_reason_code_required",
        "allowed_raw_detail_reason_codes"
      ],
      "properties": {
        "raw_excerpts_allowed": { "type": "boolean", "const": false },
        "evidence_refs_required": { "type": "boolean", "const": true },
        "summary_mode": { "const": "paraphrased_patterns_only" },
        "raw_detail_review_path": { "const": "source_report_under_controlled_review" },
        "raw_detail_reason_code_required": { "type": "boolean", "const": true },
        "allowed_raw_detail_reason_codes": {
          "description": "Controlled reason codes required before drilling into raw source-report detail outside the fleet artifact.",
          "type": "array",
          "prefixItems": [
            { "const": "validate-pattern" },
            { "const": "resolve-ambiguity" },
            { "const": "audit-safety" }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        }
      }
    },
    "sample_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_count", "selection_rule"],
      "properties": {
        "source_count": { "type": "integer", "minimum": 2 },
        "selection_rule": { "type": "string", "minLength": 1 },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "ended_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "cross_developer_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern_id",
          "problem",
          "source_count",
          "total_frequency",
          "severity",
          "implicated_component",
          "evidence_refs",
          "main_bundle_candidate"
        ],
        "properties": {
          "pattern_id": { "type": "string", "minLength": 1 },
          "problem": { "type": "string", "minLength": 1 },
          "source_count": { "type": "integer", "minimum": 2 },
          "total_frequency": { "type": "integer", "minimum": 2 },
          "severity": { "enum": ["low", "medium", "high"] },
          "implicated_component": {
            "description": "Evidence-backed hypothesis about the shared workflow stack component involved. This is not blame and may be unknown.",
            "enum": ["model", "system_prompt", "tool_permissions", "context_window_usage", "retrieval_strategy", "session_state", "hidden_summaries", "test_feedback", "user_workflow", "workflow_contract", "schema", "validator", "unknown"]
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "minLength": 1 }
          },
          "main_bundle_candidate": { "type": "boolean" }
        }
      }
    },
    "main_bundle_change_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "recommended_action",
          "applicability_scope",
          "default_workflow_eligible",
          "profile_hint",
          "profile_mode",
          "metric_scope",
          "diagnostic_signal_id",
          "diagnostic_signal_explanation",
          "target_surface",
          "expected_metric_movement",
          "requires_human_approval",
          "next_command"
        ],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "recommended_action": { "type": "string", "minLength": 1 },
          "applicability_scope": {
            "enum": ["universal", "stack_specific"],
            "description": "Universal candidates may affect the default workflow. Stack-specific candidates must be routed to optional profile guidance."
          },
          "default_workflow_eligible": { "type": "boolean" },
          "profile_hint": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
            "description": "Required for stack-specific candidates, such as swift-upgrade-profile or legacy-java-profile. Must be null for universal candidates."
          },
          "profile_mode": {
            "enum": ["not_applicable", "passive_guidance"],
            "description": "V1 profiles are passive guidance only. They must not override core workflow gates or become alternate execution modes."
          },
          "metric_scope": {
            "enum": ["core_metric", "profile_diagnostic_signal"],
            "description": "Universal candidates may target core metrics. Stack-specific profile candidates may only introduce diagnostic signals; they must not redefine global success metrics."
          },
          "diagnostic_signal_id": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9][a-z0-9-]{2,95}$",
            "description": "Required for profile diagnostic signals. Use controlled kebab-case, such as swift-upgrade-api-churn-surfaced-before-edit. Must be null for core metrics."
          },
          "diagnostic_signal_explanation": {
            "type": ["string", "null"],
            "minLength": 1,
            "description": "Required free-text explanation for profile diagnostic signals. Must be null for core metrics."
          },
          "target_surface": {
            "enum": ["prompt", "schema", "validator", "command_contract", "policy", "instructions", "docs", "profile", "unknown"]
          },
          "expected_metric_movement": { "type": "string", "minLength": 1 },
          "requires_human_approval": { "type": "boolean", "const": true },
          "next_command": { "type": "string", "const": "/grill" }
        }
      }
    },
    "diagnostic_signal_aliases": {
      "type": "array",
      "description": "Explicit rename/merge records for profile diagnostic signal IDs. Required to preserve trend analysis when V1 signal names evolve.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "alias_id",
          "action",
          "from_signal_id",
          "to_signal_id",
          "reason",
          "evidence_refs",
          "canonicalization_status",
          "requires_human_approval",
          "next_command"
        ],
        "properties": {
          "alias_id": {
            "type": "string",
            "pattern": "^SIG-ALIAS-[A-Za-z0-9_-]{3,64}$"
          },
          "action": { "enum": ["rename", "merge"] },
          "from_signal_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,95}$"
          },
          "to_signal_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,95}$"
          },
          "reason": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "canonicalization_status": { "const": "proposed" },
          "requires_human_approval": { "type": "boolean", "const": true },
          "next_command": { "type": "string", "const": "/grill" }
        }
      }
    },
    "local_only_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "reason_to_keep_local"],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "reason_to_keep_local": { "type": "string", "minLength": 1 }
        }
      }
    },
    "human_decision_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "options"],
      "properties": {
        "question": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": { "type": "integer", "const": 1 },
        "workflow_contract_version": { "type": "integer", "const": 1 },
        "command_contract_id": { "type": "string", "const": "evaluate-fleet.v1" },
        "command_contract_version": { "type": "integer", "const": 1 },
        "artifact_schema": { "type": "string", "const": "fleet-evaluation.schema.v1" },
        "config_instruction_version": { "type": "string", "const": "v1" }
      }
    }
  }
}
