{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GrillRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "task_id",
    "task_type",
    "primary_surface",
    "goal",
    "problem_statement",
    "source_diagnosis",
    "approach",
    "exploration_required",
    "exploration_reasons",
    "decision",
    "created_at",
    "validated_under"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "decision": { "const": "proceed" } },
        "required": ["decision"]
      },
      "then": { "required": ["success_criteria"] }
    },
    {
      "if": {
        "properties": { "decision": { "const": "stop" } },
        "required": ["decision"]
      },
      "then": { "required": ["open_blockers"] }
    },
    {
      "if": {
        "properties": { "task_type": { "const": "system_improvement" } },
        "required": ["task_type"]
      },
      "then": { "required": ["triggered_by"] }
    }
  ],
  "properties": {
    "artifact_type": { "const": "GrillRecord" },
    "schema_version": { "const": "grill.schema.v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "task_type": {
      "type": "string",
      "enum": ["feature", "bugfix", "system_improvement", "exploration"]
    },
    "primary_surface": { "enum": ["copilot_plugin", "copilot_cli"] },
    "secondary_surfaces_allowed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "goal": { "type": "string", "minLength": 1 },
    "problem_statement": { "type": "string", "minLength": 1 },
    "source_diagnosis": { "type": ["string", "null"] },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approach": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "rationale", "alternatives_rejected"],
        "properties": {
          "decision": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "alternatives_rejected": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "verification_type", "expected_signal", "observable"],
        "properties": {
          "id": { "type": "string", "pattern": "^SC-[0-9]{3}$" },
          "description": { "type": "string", "minLength": 10 },
          "verification_type": { "enum": ["command", "inspection", "log", "metric"] },
          "verification_command": { "type": "string", "minLength": 1 },
          "expected_signal": { "type": "string", "minLength": 1 },
          "observable": { "type": "boolean", "const": true }
        },
        "if": {
          "properties": { "verification_type": { "const": "command" } },
          "required": ["verification_type"]
        },
        "then": { "required": ["verification_command"] }
      }
    },
    "exploration_required": { "type": "boolean" },
    "exploration_reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "decision": { "enum": ["proceed", "stop"] },
    "open_blockers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "triggered_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "evaluation_refs", "failure_category"],
      "properties": {
        "source_type": {
          "enum": ["evaluation_failure", "human_initiative", "regression_detection"]
        },
        "evaluation_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "failure_category": {
          "enum": ["scope_violation", "incorrect_implementation", "criteria_not_met", "verification_incomplete", "quality_issue", "other"]
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": { "type": "integer", "const": 1 },
        "workflow_contract_version": { "type": "integer", "const": 1 },
        "command_contract_id": { "type": "string", "const": "grill.v1" },
        "command_contract_version": { "type": "integer", "const": 1 },
        "artifact_schema": { "type": "string", "const": "grill.schema.v1" },
        "config_instruction_version": { "type": "string", "const": "v1" }
      }
    }
  }
}
