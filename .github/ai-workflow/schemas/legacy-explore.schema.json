{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LegacyExplorationRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "task_id",
    "primary_surface",
    "source_grill",
    "trigger_reasons",
    "files_reviewed",
    "summary",
    "findings",
    "risks",
    "recommended_files_in_scope",
    "blast_radius",
    "test_surface_quality",
    "has_generated_code",
    "has_stored_procedures",
    "planning_constraints",
    "decision",
    "validated_under"
  ],
  "properties": {
    "artifact_type": { "const": "LegacyExplorationRecord" },
    "schema_version": { "const": "legacy-explore.schema.v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "primary_surface": { "enum": ["copilot_plugin", "copilot_cli"] },
    "secondary_surfaces_allowed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_grill": { "type": "string", "minLength": 1 },
    "trigger_reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "files_reviewed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "modules_reviewed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_files_in_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "operation"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "operation": { "enum": ["create", "modify", "delete"] }
        }
      }
    },
    "recommended_files_out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blast_radius": {
      "type": "object",
      "additionalProperties": false,
      "required": ["affected_files", "affected_modules", "caller_count", "confidence"],
      "properties": {
        "affected_files": { "type": ["integer", "string"] },
        "affected_modules": { "type": ["integer", "string"] },
        "caller_count": { "type": ["integer", "string"] },
        "confidence": { "enum": ["low", "medium", "high"] }
      }
    },
    "test_surface_quality": { "enum": ["low", "medium", "high"] },
    "has_generated_code": { "type": "boolean" },
    "has_stored_procedures": { "type": "boolean" },
    "planning_constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "decision": { "enum": ["proceed", "stop"] },
    "open_blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": { "type": "integer", "const": 1 },
        "workflow_contract_version": { "type": "integer", "const": 1 },
        "command_contract_id": { "type": "string", "const": "legacy-explore.v1" },
        "command_contract_version": { "type": "integer", "const": 1 },
        "artifact_schema": { "type": "string", "const": "legacy-explore.schema.v1" },
        "config_instruction_version": { "type": "string", "const": "v1" }
      }
    }
  }
}
