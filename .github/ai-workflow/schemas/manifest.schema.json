{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Workflow Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "workflow_contract_version",
    "supported_manifest_versions",
    "runtime",
    "paths",
    "commands",
    "schemas",
    "policies",
    "validators"
  ],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "minimum": 1
    },
    "workflow_contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "supported_manifest_versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "bootstrap_validator"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "bootstrap_validator": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "required": [
        "contracts_root",
        "schemas_root",
        "policies_root",
        "skills_root",
        "protocols_root",
        "validators_root",
        "artifacts_root",
        "logs_root"
      ]
    },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract",
          "file"
        ],
        "properties": {
          "contract": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "schemas": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "required": [
        "brainstorm",
        "manifest",
        "command_contract",
        "quick_task",
        "spec",
        "plan",
        "verification",
        "review"
      ]
    },
    "policies": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "required": [
        "brainstorm",
        "quick_task",
        "spec",
        "workflow",
        "retrieval",
        "verification",
        "review"
      ]
    },
    "validators": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "required": [
        "bootstrap",
        "manifest",
        "artifact",
        "plan_scope",
        "review_gate"
      ]
    }
  }
}
