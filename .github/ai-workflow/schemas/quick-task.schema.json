{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuickTaskRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "task_id",
    "primary_surface",
    "task_summary",
    "created_at",
    "files",
    "change_class",
    "verification",
    "escalation_triggered",
    "escalation_reason",
    "status",
    "validated_under",
    "eligibility_check"
  ],
  "properties": {
    "artifact_type": {
      "const": "QuickTaskRecord"
    },
    "schema_version": {
      "const": "quick-task.schema.v1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "primary_surface": {
      "enum": [
        "copilot_plugin",
        "copilot_cli"
      ]
    },
    "secondary_surfaces_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planned",
        "actual"
      ],
      "properties": {
        "planned": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "operation"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "operation": {
                "enum": [
                  "create",
                  "modify",
                  "delete"
                ]
              }
            }
          }
        },
        "actual": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "operation"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "operation": {
                "enum": [
                  "create",
                  "modify",
                  "delete"
                ]
              }
            }
          }
        }
      }
    },
    "change_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "policy_allowed",
        "classification_status",
        "public_behavior_change"
      ],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "policy_allowed": {
          "type": "boolean"
        },
        "classification_status": {
          "enum": [
            "proposed",
            "revised_before_edit",
            "locked_for_execution"
          ]
        },
        "public_behavior_change": {
          "type": "boolean"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "evidence"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "escalation_triggered": {
      "type": "boolean"
    },
    "escalation_reason": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": [
        "PASS_QUICK",
        "FAIL",
        "ESCALATED_TO_FULL_WORKFLOW"
      ]
    },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": {
          "type": "integer",
          "const": 1
        },
        "workflow_contract_version": {
          "type": "integer",
          "const": 1
        },
        "command_contract_id": {
          "type": "string",
          "const": "quick-task.v1"
        },
        "command_contract_version": {
          "type": "integer",
          "const": 1
        },
        "artifact_schema": {
          "type": "string",
          "const": "quick-task.schema.v1"
        },
        "config_instruction_version": {
          "type": "string",
          "const": "v1"
        }
      }
    },
    "eligibility_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rules_evaluated",
        "all_passed",
        "failures"
      ],
      "properties": {
        "rules_evaluated": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rule",
              "passed"
            ],
            "properties": {
              "rule": {
                "type": "string",
                "minLength": 1
              },
              "passed": {
                "type": "boolean"
              }
            }
          }
        },
        "all_passed": {
          "type": "boolean"
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
