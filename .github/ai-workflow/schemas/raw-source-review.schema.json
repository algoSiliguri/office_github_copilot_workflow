{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawSourceReviewRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "review_id",
    "created_at",
    "source_fleet_evaluation",
    "source_id",
    "source_report_ref",
    "reason_code",
    "requested_by_role",
    "reviewed_at",
    "evidence_refs",
    "outcome_summary",
    "raw_excerpts_included",
    "copied_raw_detail",
    "validated_under"
  ],
  "properties": {
    "artifact_type": { "const": "RawSourceReviewRecord" },
    "schema_version": { "const": "raw-source-review.schema.v1" },
    "review_id": {
      "type": "string",
      "pattern": "^RAW-SOURCE-REVIEW-[0-9]{8}-[0-9]{6}$"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "source_fleet_evaluation": {
      "type": "string",
      "pattern": "^FLEET-EVAL-[0-9]{8}-[0-9]{6}$"
    },
    "source_id": {
      "type": "string",
      "pattern": "^SRC-[A-Za-z0-9_-]{6,64}$",
      "description": "Stable pseudonymous source ID. Do not use real names or email addresses."
    },
    "source_report_ref": { "type": "string", "minLength": 1 },
    "reason_code": {
      "enum": ["validate-pattern", "resolve-ambiguity", "audit-safety"]
    },
    "requested_by_role": {
      "enum": ["workflow_maintainer", "reviewer", "auditor"]
    },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "outcome_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Paraphrased outcome only. Do not include raw excerpts or direct quotes."
    },
    "raw_excerpts_included": { "type": "boolean", "const": false },
    "copied_raw_detail": { "type": "boolean", "const": false },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": { "type": "integer", "const": 1 },
        "workflow_contract_version": { "type": "integer", "const": 1 },
        "command_contract_id": { "type": "string", "const": "evaluate-fleet.v1" },
        "command_contract_version": { "type": "integer", "const": 1 },
        "artifact_schema": { "type": "string", "const": "raw-source-review.schema.v1" },
        "config_instruction_version": { "type": "string", "const": "v1" }
      }
    }
  }
}
