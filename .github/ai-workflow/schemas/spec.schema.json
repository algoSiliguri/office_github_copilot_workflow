{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "status",
    "task_summary",
    "source_context",
    "scope",
    "requirements",
    "constraints",
    "open_questions",
    "review",
    "handoff"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "spec.schema.v1"
    },
    "command": {
      "type": "string",
      "const": "/write-spec"
    },
    "status": {
      "type": "string",
      "enum": [
        "READY_FOR_PLAN",
        "BLOCKED"
      ]
    },
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "original_request"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "direct_request",
            "quick_task_escalation"
          ]
        },
        "original_request": {
          "type": "string",
          "minLength": 1
        },
        "source_artifact": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition",
        "notes"
      ],
      "properties": {
        "disposition": {
          "type": "string",
          "enum": [
            "READY_FOR_PLAN",
            "BLOCKED"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_next_command"
      ],
      "properties": {
        "recommended_next_command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifies the task; used to locate artifact storage path."
    },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest_version": {
          "type": "integer"
        },
        "policy_version": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "validated_at": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "affected_paths"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "affected_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
