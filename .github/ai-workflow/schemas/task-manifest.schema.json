{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "task_id",
    "task_type",
    "created_at",
    "updated_at",
    "status",
    "phase",
    "artifact_refs"
  ],
  "properties": {
    "artifact_type": { "const": "TaskManifest" },
    "schema_version": { "const": "task-manifest.schema.v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "task_type": {
      "type": "string",
      "enum": ["feature", "bugfix", "system_improvement", "exploration"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["in_progress", "completed", "blocked", "abandoned"]
    },
    "phase": {
      "type": "string",
      "enum": ["diagnosis", "grill", "legacy_exploration", "plan", "context_packet", "execution", "verification", "review", "evaluated"]
    },
    "artifact_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diagnosis", "grill", "legacy_exploration", "plan", "context_packet", "execution", "verification", "review", "evaluation"],
      "properties": {
        "diagnosis": { "type": ["string", "null"] },
        "grill": { "type": ["string", "null"] },
        "legacy_exploration": { "type": ["string", "null"] },
        "plan": { "type": ["string", "null"] },
        "context_packet": { "type": ["string", "null"] },
        "execution": { "type": ["string", "null"] },
        "verification": { "type": ["string", "null"] },
        "review": { "type": ["string", "null"] },
        "evaluation": { "type": ["string", "null"] }
      }
    }
  }
}
