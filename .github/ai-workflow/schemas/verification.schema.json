{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verification Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "status",
    "task_summary",
    "plan_ref",
    "changed_files",
    "evidence",
    "review",
    "handoff"
  ],
  "properties": {
    "schema_version": {
      "const": "verification.schema.v1"
    },
    "command": {
      "const": "/verify"
    },
    "status": {
      "enum": ["VERIFIED", "VERIFIED_WITH_DEGRADATION", "FAILED", "BLOCKED"]
    },
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "outstanding_risks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition", "notes"],
      "properties": {
        "disposition": {
          "enum": ["VERIFIED", "VERIFIED_WITH_DEGRADATION", "FAILED", "BLOCKED"]
        },
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "verification_command_run": {
      "type": "string",
      "minLength": 1,
      "description": "Exact command that was executed. Must match plan.verification_command when that field is set."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifies the task; used to locate artifact storage path."
    },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest_version": {"type": "integer"},
        "policy_version": {"type": "string"},
        "schema_version": {"type": "string"},
        "validated_at": {"type": "string"}
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended_next_command"],
      "properties": {
        "recommended_next_command": {
          "const": "/review"
        }
      }
    }
  }
}
