#!/usr/bin/env python3
import sys
from pathlib import Path

import yaml


MANIFEST_PATH = Path(".github/ai-workflow/manifest.yaml")


def block(reason: str) -> int:
    print(f"BLOCKED: {reason}")
    return 1


def main() -> int:
    if not MANIFEST_PATH.exists():
        return block(f"missing manifest: {MANIFEST_PATH}")

    try:
        manifest = yaml.safe_load(MANIFEST_PATH.read_text())
    except Exception as exc:
        return block(f"manifest unreadable: {exc}")

    if not isinstance(manifest, dict):
        return block("manifest must be a mapping")

    version = manifest.get("manifest_version")
    supported = manifest.get("supported_manifest_versions")
    if version is None or not isinstance(supported, list):
        return block("manifest missing version metadata")
    if version not in supported:
        return block(f"unsupported manifest_version: {version}")

    runtime = manifest.get("runtime")
    if not isinstance(runtime, dict):
        return block("manifest.runtime must be a mapping")
    bootstrap_validator = runtime.get("bootstrap_validator")
    if not bootstrap_validator:
        return block("manifest.runtime.bootstrap_validator is required")
    config_path = runtime.get("config")
    if not config_path:
        return block("manifest.runtime.config is required")

    missing = []

    def collect_paths(node):
        if isinstance(node, str) and node.startswith(".github/ai-workflow/"):
            missing.append(node)
        elif isinstance(node, dict):
            for value in node.values():
                collect_paths(value)
        elif isinstance(node, list):
            for value in node:
                collect_paths(value)

    collect_paths(runtime)
    collect_paths(manifest.get("paths", {}))
    collect_paths(manifest.get("commands", {}))
    collect_paths(manifest.get("schemas", {}))
    collect_paths(manifest.get("policies", {}))
    collect_paths(manifest.get("validators", {}))

    seen = []
    for raw_path in missing:
        path = Path(raw_path)
        if raw_path not in seen:
            seen.append(raw_path)
        if not path.exists():
            return block(f"missing required path: {raw_path}")

    print("PASS")
    return 0


if __name__ == "__main__":
    sys.exit(main())
