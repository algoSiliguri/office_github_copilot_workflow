#!/usr/bin/env python3
import sys
from pathlib import Path

import yaml


ALLOWED_OPERATIONS = {"create", "modify", "delete"}
ALLOWED_QUICK_TASK_STATUS = {"PASS_QUICK", "FAIL", "ESCALATED_TO_FULL_WORKFLOW"}
ALLOWED_PLAN_STATUS = {"READY", "DEGRADED", "BLOCKED"}
ALLOWED_VERIFICATION_STATUS = {"VERIFIED", "VERIFIED_WITH_DEGRADATION", "FAILED", "BLOCKED"}
ALLOWED_REVIEW_STATUS = {"PASS", "PASS_WITH_DEGRADATION", "FAIL", "BLOCKED"}
EXPECTED_TUPLES = {
    "grill.schema.v1": ("grill.v1", "grill.schema.v1"),
    "legacy-explore.schema.v1": ("legacy-explore.v1", "legacy-explore.schema.v1"),
    "quick-task.schema.v1": ("quick-task.v1", "quick-task.schema.v1"),
    "plan.schema.v1": ("write-plan.v1", "plan.schema.v1"),
    "context-packet.schema.v1": ("context-packet.v1", "context-packet.schema.v1"),
    "execution-checkpoint.schema.v1": ("execute-plan.v1", "execution-checkpoint.schema.v1"),
    "verification.schema.v1": ("verify.v1", "verification.schema.v1"),
    "review.schema.v1": ("review.v1", "review.schema.v1"),
}


MONOLITH_FIELDS = ["blast_radius", "test_surface_quality", "has_generated_code", "has_stored_procedures", "planning_constraints"]


def fail(reason: str) -> int:
    print(f"FAIL: {reason}")
    return 1


def migration_required(artifact_path: str, artifact_type: str, missing_fields: list, found_schema: str, expected_schema: str) -> int:
    print(f"MIGRATION_REQUIRED: {artifact_path}")
    print(f"  artifact_type:    {artifact_type}")
    print(f"  found_schema:     {found_schema}")
    print(f"  expected_schema:  {expected_schema}")
    print(f"  missing_fields:   {', '.join(missing_fields)}")
    print(f"  action:           re-run the phase command that produced this artifact")
    return 2


def require(condition: bool, reason: str):
    if not condition:
        raise ValueError(reason)


def require_string(value, path: str):
    require(isinstance(value, str) and value.strip(), f"{path} must be a non-empty string")


def load_artifact(path_arg: str):
    path = Path(path_arg)
    require(path.exists(), f"artifact does not exist: {path}")
    data = yaml.safe_load(path.read_text())
    require(isinstance(data, dict), "artifact must be a mapping")
    return data


def validate_string_list(entries, path: str):
    require(isinstance(entries, list), f"{path} must be a list")
    for idx, value in enumerate(entries):
        require_string(value, f"{path}[{idx}]")


def validate_file_entries(entries, path: str):
    require(isinstance(entries, list), f"{path} must be a list")
    for idx, entry in enumerate(entries):
        require(isinstance(entry, dict), f"{path}[{idx}] must be a mapping")
        require_string(entry.get("path"), f"{path}[{idx}].path")
        require(entry.get("operation") in ALLOWED_OPERATIONS, f"{path}[{idx}].operation must be one of {sorted(ALLOWED_OPERATIONS)}")


def validate_validated_under(artifact):
    schema_version = artifact.get("schema_version")
    require(schema_version in EXPECTED_TUPLES, f"unsupported schema_version: {schema_version!r}")
    expected_command, expected_schema = EXPECTED_TUPLES[schema_version]
    vu = artifact.get("validated_under")
    require(isinstance(vu, dict), "validated_under must be a mapping")
    require(vu.get("workflow_manifest_version") == 1, "validated_under.workflow_manifest_version must be 1")
    require(vu.get("workflow_contract_version") == 1, "validated_under.workflow_contract_version must be 1")
    require(vu.get("command_contract_id") == expected_command, f"validated_under.command_contract_id must be {expected_command}")
    require(vu.get("command_contract_version") == 1, "validated_under.command_contract_version must be 1")
    require(vu.get("artifact_schema") == expected_schema, f"validated_under.artifact_schema must be {expected_schema}")
    require(vu.get("config_instruction_version") == "v1", "validated_under.config_instruction_version must be v1")


def validate_grill(artifact):
    require(artifact.get("artifact_type") == "GrillRecord", "artifact_type must be GrillRecord")
    require_string(artifact.get("task_id"), "task_id")
    require(artifact.get("primary_surface") in {"copilot_plugin", "copilot_cli"}, "primary_surface must be copilot_plugin or copilot_cli")
    require_string(artifact.get("goal"), "goal")
    require_string(artifact.get("problem_statement"), "problem_statement")
    approach = artifact.get("approach")
    require(isinstance(approach, list) and approach, "approach must be a non-empty list")
    for idx, item in enumerate(approach):
        require(isinstance(item, dict), f"approach[{idx}] must be a mapping")
        require_string(item.get("decision"), f"approach[{idx}].decision")
        require_string(item.get("rationale"), f"approach[{idx}].rationale")
        validate_string_list(item.get("alternatives_rejected"), f"approach[{idx}].alternatives_rejected")
    exploration_required = artifact.get("exploration_required")
    require(isinstance(exploration_required, bool), "exploration_required must be boolean")
    exploration_reasons = artifact.get("exploration_reasons")
    validate_string_list(exploration_reasons, "exploration_reasons")
    if exploration_required:
        require(bool(exploration_reasons), "exploration_required=true requires exploration_reasons")
    else:
        require(not exploration_reasons, "exploration_reasons must be empty when exploration_required=false")
    require(artifact.get("decision") in {"proceed", "stop"}, "decision must be proceed or stop")


class MigrationRequired(Exception):
    def __init__(self, missing_fields: list):
        self.missing_fields = missing_fields


def validate_legacy_explore(artifact):
    require(artifact.get("artifact_type") == "LegacyExplorationRecord", "artifact_type must be LegacyExplorationRecord")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("source_grill"), "source_grill")
    validate_string_list(artifact.get("trigger_reasons"), "trigger_reasons")
    validate_string_list(artifact.get("files_reviewed"), "files_reviewed")
    require_string(artifact.get("summary"), "summary")
    validate_string_list(artifact.get("findings"), "findings")
    validate_string_list(artifact.get("risks"), "risks")
    validate_file_entries(artifact.get("recommended_files_in_scope"), "recommended_files_in_scope")
    require(artifact.get("decision") in {"proceed", "stop"}, "decision must be proceed or stop")
    if artifact.get("decision") == "stop":
        validate_string_list(artifact.get("open_blockers"), "open_blockers")
        require(bool(artifact.get("open_blockers")), "stop decision requires open_blockers")
    missing = [f for f in MONOLITH_FIELDS if f not in artifact]
    if missing:
        raise MigrationRequired(missing)


def validate_quick_task(artifact):
    require(artifact.get("artifact_type") == "QuickTaskRecord", "artifact_type must be QuickTaskRecord")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("task_summary"), "task_summary")
    files = artifact.get("files")
    require(isinstance(files, dict), "files must be a mapping")
    validate_file_entries(files.get("planned"), "files.planned")
    validate_file_entries(files.get("actual"), "files.actual")
    planned = {entry["path"] for entry in files["planned"]}
    actual = {entry["path"] for entry in files["actual"]}
    require(actual.issubset(planned), "files.actual must be a subset of files.planned")
    change_class = artifact.get("change_class")
    require(isinstance(change_class, dict), "change_class must be a mapping")
    require_string(change_class.get("value"), "change_class.value")
    require(isinstance(change_class.get("policy_allowed"), bool), "change_class.policy_allowed must be boolean")
    require(change_class.get("classification_status") in {"proposed", "revised_before_edit", "locked_for_execution"}, "change_class.classification_status must be valid")
    require(isinstance(change_class.get("public_behavior_change"), bool), "change_class.public_behavior_change must be boolean")
    verification = artifact.get("verification")
    require(isinstance(verification, dict), "verification must be a mapping")
    require_string(verification.get("command"), "verification.command")
    validate_string_list(verification.get("evidence"), "verification.evidence")
    require(isinstance(artifact.get("escalation_triggered"), bool), "escalation_triggered must be boolean")
    validate_string_list(artifact.get("escalation_reason"), "escalation_reason")
    status = artifact.get("status")
    require(status in ALLOWED_QUICK_TASK_STATUS, f"status must be one of {sorted(ALLOWED_QUICK_TASK_STATUS)}")
    if artifact.get("escalation_triggered"):
        require(status == "ESCALATED_TO_FULL_WORKFLOW", "escalation_triggered=true requires ESCALATED_TO_FULL_WORKFLOW")
        require(bool(artifact.get("escalation_reason")), "escalation requires escalation_reason")
    if change_class.get("policy_allowed") is False or change_class.get("public_behavior_change") is True:
        require(status == "ESCALATED_TO_FULL_WORKFLOW", "forbidden or public-behavior-changing quick-task must escalate")
    if status == "PASS_QUICK":
        require(change_class.get("policy_allowed") is True, "PASS_QUICK requires policy_allowed=true")
        require(bool(verification.get("evidence")), "PASS_QUICK requires verification evidence")


def validate_plan(artifact):
    require(artifact.get("artifact_type") == "PlanArtifact", "artifact_type must be PlanArtifact")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("source_grill"), "source_grill")
    source_exploration = artifact.get("source_exploration")
    require(source_exploration is None or (isinstance(source_exploration, str) and source_exploration.strip()), "source_exploration must be null or non-empty string")
    validate_file_entries(artifact.get("files_in_scope"), "files_in_scope")
    validate_string_list(artifact.get("files_out_of_scope"), "files_out_of_scope")
    require(isinstance(artifact.get("context_packet_required"), bool), "context_packet_required must be boolean")
    if artifact.get("context_packet_required"):
        require_string(artifact.get("context_packet_path"), "context_packet_path")
    scope_paths = {entry["path"] for entry in artifact["files_in_scope"]}
    steps = artifact.get("steps")
    require(isinstance(steps, list) and steps, "steps must be a non-empty list")
    step_ids = set()
    for idx, step in enumerate(steps):
        require(isinstance(step, dict), f"steps[{idx}] must be a mapping")
        sid = step.get("id")
        require_string(sid, f"steps[{idx}].id")
        require(sid not in step_ids, f"steps[{idx}].id must be unique")
        step_ids.add(sid)
        require_string(step.get("summary"), f"steps[{idx}].summary")
        require(step.get("preferred_surface") in {"copilot_plugin", "copilot_cli"}, f"steps[{idx}].preferred_surface must be copilot_plugin or copilot_cli")
        validate_file_entries(step.get("files"), f"steps[{idx}].files")
        for fidx, fentry in enumerate(step["files"]):
            require(fentry["path"] in scope_paths, f"steps[{idx}].files[{fidx}].path '{fentry['path']}' is not declared in files_in_scope")
        validate_string_list(step.get("allowed_cli_commands"), f"steps[{idx}].allowed_cli_commands")
        require_string(step.get("verification_command"), f"steps[{idx}].verification_command")
        require(step.get("risk_class") in {"safe", "degraded", "high-risk"}, f"steps[{idx}].risk_class must be safe, degraded, or high-risk")
        require(isinstance(step.get("requires_human_ack"), bool), f"steps[{idx}].requires_human_ack must be boolean")
        require_string(step.get("risk_reason"), f"steps[{idx}].risk_reason")
        validate_string_list(step.get("depends_on"), f"steps[{idx}].depends_on")
        if step.get("risk_class") in {"degraded", "high-risk"}:
            require(step.get("requires_human_ack") is True, f"steps[{idx}] with risk_class {step.get('risk_class')} must require human ack")
        if step.get("risk_class") == "safe":
            require(step.get("requires_human_ack") is False, f"steps[{idx}] with risk_class safe must not require human ack")
        if step.get("preferred_surface") == "copilot_cli":
            require(bool(step.get("allowed_cli_commands")), f"steps[{idx}] with preferred_surface=copilot_cli must declare allowed_cli_commands")
    require_string(artifact.get("verification_command"), "verification_command")
    validate_string_list(artifact.get("constraints"), "constraints")


def validate_context_packet(artifact):
    require(artifact.get("artifact_type") == "ContextPacketArtifact", "artifact_type must be ContextPacketArtifact")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("phase_id"), "phase_id")
    require_string(artifact.get("source_plan"), "source_plan")
    require_string(artifact.get("generated_at"), "generated_at")
    require(isinstance(artifact.get("scope"), dict), "scope must be a mapping")
    require(isinstance(artifact.get("retrieval_policy"), dict), "retrieval_policy must be a mapping")
    require(isinstance(artifact.get("coverage"), dict), "coverage must be a mapping")
    require(isinstance(artifact.get("included_context"), list), "included_context must be a list")
    require(isinstance(artifact.get("execution_decision"), dict), "execution_decision must be a mapping")
    require(isinstance(artifact.get("validation"), dict), "validation must be a mapping")


def validate_execution(artifact):
    require(artifact.get("artifact_type") == "ExecutionRecord", "artifact_type must be ExecutionRecord")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("source_plan"), "source_plan")
    validate_string_list(artifact.get("step_ids"), "step_ids")
    require(artifact.get("status") in {"in_progress", "completed", "blocked", "escalated"}, "status must be in_progress, completed, blocked, or escalated")
    plan_scope = artifact.get("plan_scope")
    require(isinstance(plan_scope, dict), "plan_scope must be a mapping")
    validate_string_list(plan_scope.get("files_authorized"), "plan_scope.files_authorized")
    actual_changes = artifact.get("actual_changes")
    require(isinstance(actual_changes, dict), "actual_changes must be a mapping")
    validate_string_list(actual_changes.get("files_touched"), "actual_changes.files_touched")
    validate_string_list(actual_changes.get("unplanned_files_touched"), "actual_changes.unplanned_files_touched")
    cli_handoff = artifact.get("cli_handoff")
    require(isinstance(cli_handoff, dict), "cli_handoff must be a mapping")
    require(cli_handoff.get("approval_status") in {"not_required", "pending", "approved", "rejected"}, "cli_handoff.approval_status must be valid")
    require_string(cli_handoff.get("reason"), "cli_handoff.reason")
    validate_string_list(cli_handoff.get("allowed_commands"), "cli_handoff.allowed_commands")
    validate_string_list(cli_handoff.get("allowed_files"), "cli_handoff.allowed_files")
    validate_string_list(cli_handoff.get("blocked_actions"), "cli_handoff.blocked_actions")
    require_string(cli_handoff.get("expected_return_artifact"), "cli_handoff.expected_return_artifact")
    human_acks = artifact.get("human_acknowledgments")
    require(isinstance(human_acks, list), "human_acknowledgments must be a list")
    for idx, ack in enumerate(human_acks):
        require(isinstance(ack, dict), f"human_acknowledgments[{idx}] must be a mapping")
        require_string(ack.get("step_id"), f"human_acknowledgments[{idx}].step_id")
        require(ack.get("status") in {"pending", "approved", "rejected"}, f"human_acknowledgments[{idx}].status must be valid")
        require_string(ack.get("reviewer"), f"human_acknowledgments[{idx}].reviewer")
        require_string(ack.get("reason"), f"human_acknowledgments[{idx}].reason")
    commands_run = artifact.get("commands_run")
    require(isinstance(commands_run, list), "commands_run must be a list")
    for idx, cmd in enumerate(commands_run):
        require(isinstance(cmd, dict), f"commands_run[{idx}] must be a mapping")
        require_string(cmd.get("command"), f"commands_run[{idx}].command")
        require_string(cmd.get("output"), f"commands_run[{idx}].output")
    decision = artifact.get("decision")
    require(isinstance(decision, dict), "decision must be a mapping")
    require(decision.get("status") in {"continue", "stop", "escalate"}, "decision.status must be continue, stop, or escalate")
    require_string(decision.get("reason"), "decision.reason")


def validate_verification(artifact):
    require(artifact.get("artifact_type") == "VerificationRecord", "artifact_type must be VerificationRecord")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("plan_ref"), "plan_ref")
    require_string(artifact.get("execution_ref"), "execution_ref")
    validate_string_list(artifact.get("changed_files"), "changed_files")
    require_string(artifact.get("verification_command"), "verification_command")
    require_string(artifact.get("verification_command_run"), "verification_command_run")
    require_string(artifact.get("command_output"), "command_output")
    validate_string_list(artifact.get("evidence"), "evidence")
    status = artifact.get("status")
    require(status in ALLOWED_VERIFICATION_STATUS, f"status must be one of {sorted(ALLOWED_VERIFICATION_STATUS)}")
    degraded_reason = artifact.get("degraded_reason")
    human_ack = artifact.get("human_acknowledgment")
    if status == "VERIFIED_WITH_DEGRADATION":
        require(isinstance(degraded_reason, str) and degraded_reason.strip(), "VERIFIED_WITH_DEGRADATION requires degraded_reason")
        require(isinstance(human_ack, dict), "VERIFIED_WITH_DEGRADATION requires human_acknowledgment")
        require(human_ack.get("status") == "approved", "degraded verification requires approved human_acknowledgment")
        require_string(human_ack.get("reviewer"), "human_acknowledgment.reviewer")
        require_string(human_ack.get("reason"), "human_acknowledgment.reason")
    elif human_ack is not None:
        require(isinstance(human_ack, dict), "human_acknowledgment must be null or a mapping")


def validate_review(artifact):
    require(artifact.get("artifact_type") == "ReviewRecord", "artifact_type must be ReviewRecord")
    require_string(artifact.get("task_id"), "task_id")
    require_string(artifact.get("plan_ref"), "plan_ref")
    require_string(artifact.get("execution_ref"), "execution_ref")
    require_string(artifact.get("verification_ref"), "verification_ref")
    validate_string_list(artifact.get("actual_changed_files"), "actual_changed_files")
    validate_string_list(artifact.get("scope_violations"), "scope_violations")
    scope_match = artifact.get("scope_match")
    require(isinstance(scope_match, bool), "scope_match must be boolean")
    if scope_match:
        require(not artifact.get("scope_violations"), "scope_match=true requires empty scope_violations")
    else:
        require(bool(artifact.get("scope_violations")), "scope_match=false requires scope_violations")
    status = artifact.get("status")
    require(status in ALLOWED_REVIEW_STATUS, f"status must be one of {sorted(ALLOWED_REVIEW_STATUS)}")
    human_auth = artifact.get("human_authorization")
    if status in {"PASS", "PASS_WITH_DEGRADATION"}:
        require(scope_match is True, f"{status} requires scope_match=true")
        require(isinstance(human_auth, dict), f"{status} requires human_authorization")
        require(human_auth.get("status") == "approved", f"{status} requires approved human_authorization")
        require_string(human_auth.get("reviewer"), "human_authorization.reviewer")
    if status == "PASS_WITH_DEGRADATION":
        require(isinstance(artifact.get("degraded_reason"), str) and artifact["degraded_reason"].strip(), "PASS_WITH_DEGRADATION requires degraded_reason")


def main() -> int:
    if len(sys.argv) != 2:
        return fail("usage: validate-artifact <artifact-path>")

    artifact_path = sys.argv[1]
    try:
        artifact = load_artifact(artifact_path)
        validate_validated_under(artifact)
        schema_version = artifact.get("schema_version")
        if schema_version == "grill.schema.v1":
            validate_grill(artifact)
        elif schema_version == "legacy-explore.schema.v1":
            validate_legacy_explore(artifact)
        elif schema_version == "quick-task.schema.v1":
            validate_quick_task(artifact)
        elif schema_version == "plan.schema.v1":
            validate_plan(artifact)
        elif schema_version == "context-packet.schema.v1":
            validate_context_packet(artifact)
        elif schema_version == "execution-checkpoint.schema.v1":
            validate_execution(artifact)
        elif schema_version == "verification.schema.v1":
            validate_verification(artifact)
        elif schema_version == "review.schema.v1":
            validate_review(artifact)
        else:
            raise ValueError("unsupported schema_version")
        print("PASS")
        return 0
    except MigrationRequired as exc:
        return migration_required(
            artifact_path,
            artifact.get("artifact_type", "unknown"),
            exc.missing_fields,
            artifact.get("schema_version", "unknown"),
            "legacy-explore.schema.v1 (current)",
        )
    except ValueError as exc:
        return fail(str(exc))
    except Exception as exc:
        return fail(f"unexpected validation error: {exc}")


if __name__ == "__main__":
    sys.exit(main())
