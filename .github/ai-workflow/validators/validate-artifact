        require_string(candidate.get("expected_metric_movement"), f"main_bundle_change_candidates[{idx}].expected_metric_movement")
        require(candidate.get("requires_human_approval") is True, f"main_bundle_change_candidates[{idx}].requires_human_approval must be true")
        require(candidate.get("next_command") == "/grill", f"main_bundle_change_candidates[{idx}].next_command must be /grill")

    aliases = artifact.get("diagnostic_signal_aliases")
    require(isinstance(aliases, list), "diagnostic_signal_aliases must be a list")
    for idx, alias in enumerate(aliases):
        require(isinstance(alias, dict), f"diagnostic_signal_aliases[{idx}] must be an object")
        require_string(alias.get("alias_id"), f"diagnostic_signal_aliases[{idx}].alias_id")
        require(re.match(r"^SIG-ALIAS-[A-Za-z0-9_-]{3,64}$", alias["alias_id"]) is not None, f"diagnostic_signal_aliases[{idx}].alias_id must match SIG-ALIAS-{{token}}")
        require(alias.get("action") in {"rename", "merge"}, f"diagnostic_signal_aliases[{idx}].action must be rename or merge")
        from_signal = alias.get("from_signal_id")
        to_signal = alias.get("to_signal_id")
        require(isinstance(from_signal, str), f"diagnostic_signal_aliases[{idx}].from_signal_id must be string")
        require(isinstance(to_signal, str), f"diagnostic_signal_aliases[{idx}].to_signal_id must be string")
        require(re.match(r"^[a-z0-9][a-z0-9-]{2,95}$", from_signal) is not None, f"diagnostic_signal_aliases[{idx}].from_signal_id must be controlled kebab-case")
        require(re.match(r"^[a-z0-9][a-z0-9-]{2,95}$", to_signal) is not None, f"diagnostic_signal_aliases[{idx}].to_signal_id must be controlled kebab-case")
        require(from_signal != to_signal, f"diagnostic_signal_aliases[{idx}] must map different signal IDs")
        require("http" not in from_signal and "/" not in from_signal and "@" not in from_signal, f"diagnostic_signal_aliases[{idx}].from_signal_id must not contain URLs or email-like identifiers")
        require("http" not in to_signal and "/" not in to_signal and "@" not in to_signal, f"diagnostic_signal_aliases[{idx}].to_signal_id must not contain URLs or email-like identifiers")
        require_string(alias.get("reason"), f"diagnostic_signal_aliases[{idx}].reason")
        validate_string_list(alias.get("evidence_refs"), f"diagnostic_signal_aliases[{idx}].evidence_refs", allow_empty=False)
        require(alias.get("canonicalization_status") == "proposed", f"diagnostic_signal_aliases[{idx}].canonicalization_status must be proposed")
        require(alias.get("requires_human_approval") is True, f"diagnostic_signal_aliases[{idx}].requires_human_approval must be true")
        require(alias.get("next_command") == "/grill", f"diagnostic_signal_aliases[{idx}].next_command must be /grill")

    local = artifact.get("local_only_candidates")
    require(isinstance(local, list), "local_only_candidates must be a list")
    for idx, candidate in enumerate(local):
        require(isinstance(candidate, dict), f"local_only_candidates[{idx}] must be an object")
        require_string(candidate.get("candidate_id"), f"local_only_candidates[{idx}].candidate_id")
        require_string(candidate.get("reason_to_keep_local"), f"local_only_candidates[{idx}].reason_to_keep_local")

    decision = artifact.get("human_decision_request")
    require(isinstance(decision, dict), "human_decision_request must be an object")
    require_string(decision.get("question"), "human_decision_request.question")
    validate_string_list(decision.get("options"), "human_decision_request.options", allow_empty=False)


def validate_raw_source_review(artifact):
    require(artifact.get("artifact_type") == "RawSourceReviewRecord", "artifact_type must be RawSourceReviewRecord")
    require_string(artifact.get("review_id"), "review_id")
    require(re.match(r"^RAW-SOURCE-REVIEW-\d{8}-\d{6}$", artifact["review_id"]) is not None, "review_id must match RAW-SOURCE-REVIEW-YYYYMMDD-HHMMSS")
    require_string(artifact.get("created_at"), "created_at")
    require_string(artifact.get("reviewed_at"), "reviewed_at")
    source_fleet = artifact.get("source_fleet_evaluation")
    require(isinstance(source_fleet, str), "source_fleet_evaluation must be string")
    require(re.match(r"^FLEET-EVAL-\d{8}-\d{6}$", source_fleet) is not None, "source_fleet_evaluation must match FLEET-EVAL-YYYYMMDD-HHMMSS")
    source_id = artifact.get("source_id")
    require(isinstance(source_id, str), "source_id must be string")
    require(re.match(r"^SRC-[A-Za-z0-9_-]{6,64}$", source_id) is not None, "source_id must match SRC-{stable-token}")
    require("@" not in source_id, "source_id must not contain email-like identifiers")
    require_string(artifact.get("source_report_ref"), "source_report_ref")
    require(artifact.get("reason_code") in {"validate-pattern", "resolve-ambiguity", "audit-safety"}, "reason_code must be validate-pattern, resolve-ambiguity, or audit-safety")
    require(artifact.get("requested_by_role") in {"workflow_maintainer", "reviewer", "auditor"}, "requested_by_role must be workflow_maintainer, reviewer, or auditor")
    validate_string_list(artifact.get("evidence_refs"), "evidence_refs", allow_empty=False)
    require_string(artifact.get("outcome_summary"), "outcome_summary")
    require(artifact.get("raw_excerpts_included") is False, "raw_excerpts_included must be false")
    require(artifact.get("copied_raw_detail") is False, "copied_raw_detail must be false")


def main() -> int:
    if len(sys.argv) != 2:
        return fail("usage: validate-artifact <artifact-path>")

    try:
        artifact = load_json(sys.argv[1])
        validate_validated_under(artifact)
        schema_version = artifact.get("schema_version")
        if schema_version == "diagnosis.schema.v1":
            validate_diagnosis(artifact)
        elif schema_version == "grill.schema.v1":
            validate_grill(artifact)
        elif schema_version == "legacy-explore.schema.v1":
            validate_legacy_explore(artifact)
        elif schema_version == "quick-task.schema.v1":
            validate_quick_task(artifact)
        elif schema_version == "plan.schema.v1":
            validate_plan(artifact)
        elif schema_version == "context-packet.schema.v1":
            validate_context_packet(artifact)
        elif schema_version == "execution-checkpoint.schema.v1":
            validate_execution(artifact)
        elif schema_version == "verification.schema.v1":
            validate_verification(artifact)
        elif schema_version == "review.schema.v1":
            validate_review(artifact)
        elif schema_version == "task-manifest.schema.v1":
            validate_task_manifest(artifact)
        elif schema_version == "evaluation.schema.v1":
            validate_evaluation(artifact)
        elif schema_version == "system-evaluation.schema.v1":
            validate_system_evaluation(artifact)
        elif schema_version == "fleet-evaluation.schema.v1":
            validate_fleet_evaluation(artifact)
        elif schema_version == "raw-source-review.schema.v1":
            validate_raw_source_review(artifact)
        else:
            raise ValueError("unsupported schema_version")
        print("PASS")
        return 0
    except ValueError as exc:
        return fail(str(exc))
    except Exception as exc:
        return fail(f"unexpected validation error: {exc}")


if __name__ == "__main__":
    sys.exit(main())
