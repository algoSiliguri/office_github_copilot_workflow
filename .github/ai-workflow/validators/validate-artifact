            require(profile_mode == "passive_guidance", f"main_bundle_change_candidates[{idx}].profile_mode must be passive_guidance for stack-specific candidates")
            require(metric_scope == "profile_diagnostic_signal", f"main_bundle_change_candidates[{idx}].metric_scope must be profile_diagnostic_signal for stack-specific candidates")
