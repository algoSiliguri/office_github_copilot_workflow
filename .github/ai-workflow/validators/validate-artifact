def validate_evaluation(artifact):
    validate_common(artifact, "EvaluationRecord")
    source_refs = artifact.get("source_refs")
    require(isinstance(source_refs, dict), "source_refs must be an object")
    for key in ("task_manifest", "grill", "plan", "execution", "verification", "review"):
        require_string(source_refs.get(key), f"source_refs.{key}")
    scores = artifact.get("scores")
    require(isinstance(scores, dict), "scores must be an object")
    rate = scores.get("criteria_satisfaction_rate")
    require(isinstance(rate, (int, float)) and 0.0 <= rate <= 1.0, "scores.criteria_satisfaction_rate must be between 0.0 and 1.0")
    summary = scores.get("criteria_outcomes_summary")
    require(isinstance(summary, list) and summary, "scores.criteria_outcomes_summary must be a non-empty list")
    for idx, item in enumerate(summary):
        require(isinstance(item, dict), f"scores.criteria_outcomes_summary[{idx}] must be an object")
        require_string(item.get("criterion"), f"scores.criteria_outcomes_summary[{idx}].criterion")
        require(isinstance(item.get("met"), bool), f"scores.criteria_outcomes_summary[{idx}].met must be boolean")
    require(isinstance(scores.get("scope_adherence"), bool), "scores.scope_adherence must be boolean")
    require(isinstance(scores.get("unplanned_files_count"), int) and scores["unplanned_files_count"] >= 0, "scores.unplanned_files_count must be a non-negative integer")
    require(scores.get("verification_status") in ALLOWED_VERIFICATION_STATUS, "scores.verification_status must be valid")
    require(scores.get("review_status") in ALLOWED_REVIEW_STATUS, "scores.review_status must be valid")
    require(scores.get("human_approval_first_pass") in {"approved", "rejected", "pending"}, "scores.human_approval_first_pass must be valid")
    require(isinstance(scores.get("criteria_count"), int) and scores["criteria_count"] >= 1, "scores.criteria_count must be a positive integer")
    require(isinstance(scores.get("criteria_met_count"), int) and scores["criteria_met_count"] >= 0, "scores.criteria_met_count must be a non-negative integer")
    require(isinstance(scores.get("criteria_unmet_count"), int) and scores["criteria_unmet_count"] >= 0, "scores.criteria_unmet_count must be a non-negative integer")
    require(scores.get("outcome_band") in {"success", "partial_success_high", "partial_success_low", "failure"}, "scores.outcome_band must be valid")
    task_outcome = artifact.get("task_outcome")
    require(isinstance(task_outcome, dict), "task_outcome must be an object")
    for key in ("criteria_satisfaction_rate", "criteria_count", "criteria_met_count", "criteria_unmet_count", "outcome_band"):
        require(task_outcome.get(key) == scores.get(key), f"task_outcome.{key} must match scores.{key}")
    process = artifact.get("process_quality")
    require(isinstance(process, dict), "process_quality must be an object")
    for key in ("diagnosis_used_when_required", "retrieval_decision_recorded", "tdd_decision_recorded", "tdd_followed_when_required", "verification_evidence_present", "scope_adherence", "human_gate_respected"):
        require(isinstance(process.get(key), bool), f"process_quality.{key} must be boolean")
    require(process.get("status") in {"pass", "degraded", "fail"}, "process_quality.status must be valid")
    validate_string_list(process.get("violations"), "process_quality.violations")
    if process.get("status") == "pass":
        require(not process.get("violations"), "process_quality.status=pass requires no violations")
    if process.get("status") == "fail":
        require(bool(process.get("violations")), "process_quality.status=fail requires violations")
    require(artifact.get("outcome") in {"success", "partial_success_high", "partial_success_low", "failure"}, "outcome must be valid")
    require(artifact.get("evaluation_status") in {"draft", "confirmed", "overridden"}, "evaluation_status must be valid")
    human = artifact.get("human_evaluation")
    require(isinstance(human, dict), "human_evaluation must be an object")
    require(human.get("status") in {"draft", "confirmed", "overridden"}, "human_evaluation.status must be valid")
    require("reviewer" in human, "human_evaluation.reviewer is required")
    if artifact.get("evaluation_status") == "draft":
        require(human.get("status") == "draft", "draft evaluation requires human_evaluation.status=draft")
    if artifact.get("evaluation_status") == "confirmed":
        require(human.get("status") == "confirmed", "confirmed evaluation requires human_evaluation.status=confirmed")
        require_string(human.get("reviewer"), "human_evaluation.reviewer")
        require_string(human.get("confirmed_at"), "human_evaluation.confirmed_at")
    if artifact.get("evaluation_status") == "overridden":
        require(human.get("status") == "overridden", "overridden evaluation requires human_evaluation.status=overridden")
        require_string(human.get("reviewer"), "human_evaluation.reviewer")
        validate_reason(human.get("override_reason"), "human_evaluation.override_reason")


