    require(re.match(r"^FLEET-EVAL-\d{8}-\d{6}$", artifact["fleet_evaluation_id"]) is not None, "fleet_evaluation_id must match FLEET-EVAL-YYYYMMDD-HHMMSS")
    require_string(artifact.get("created_at"), "created_at")

    refs = artifact.get("source_report_refs")
    require(isinstance(refs, list) and len(refs) >= 2, "source_report_refs must include at least 2 independent sources")
    source_ids = set()
    for idx, ref in enumerate(refs):
        require(isinstance(ref, dict), f"source_report_refs[{idx}] must be an object")
        require_string(ref.get("source_id"), f"source_report_refs[{idx}].source_id")
        require(re.match(r"^SRC-[A-Za-z0-9_-]{6,64}$", ref["source_id"]) is not None, f"source_report_refs[{idx}].source_id must match SRC-{{stable-token}}")
        require("@" not in ref["source_id"], f"source_report_refs[{idx}].source_id must not contain email-like identifiers")
        require_string(ref.get("report_ref"), f"source_report_refs[{idx}].report_ref")
        repository_hint = ref.get("repository_hint")
        if repository_hint is not None:
            require(isinstance(repository_hint, str), f"source_report_refs[{idx}].repository_hint must be string or null")
            require(re.match(r"^[a-z0-9][a-z0-9-]{2,63}$", repository_hint) is not None, f"source_report_refs[{idx}].repository_hint must be coarse kebab-case")
            require("http" not in repository_hint and "/" not in repository_hint and "@" not in repository_hint, f"source_report_refs[{idx}].repository_hint must not contain URLs or email-like identifiers")
        source_ids.add(ref["source_id"])
    require(len(source_ids) >= 2, "source_report_refs must contain at least 2 distinct source_id values")

    source_policy = artifact.get("source_comparison_policy")
    require(isinstance(source_policy, dict), "source_comparison_policy must be an object")
    require(source_policy.get("source_ids_used_for") == "independence_and_deduplication_only", "source_comparison_policy.source_ids_used_for must be independence_and_deduplication_only")
    require(source_policy.get("developer_ranking_allowed") is False, "source_comparison_policy.developer_ranking_allowed must be false")
    require(source_policy.get("per_source_performance_scoring_allowed") is False, "source_comparison_policy.per_source_performance_scoring_allowed must be false")

    evidence_policy = artifact.get("evidence_handling_policy")
    require(isinstance(evidence_policy, dict), "evidence_handling_policy must be an object")
    require(evidence_policy.get("raw_excerpts_allowed") is False, "evidence_handling_policy.raw_excerpts_allowed must be false")
    require(evidence_policy.get("evidence_refs_required") is True, "evidence_handling_policy.evidence_refs_required must be true")
    require(evidence_policy.get("summary_mode") == "paraphrased_patterns_only", "evidence_handling_policy.summary_mode must be paraphrased_patterns_only")
    require(evidence_policy.get("raw_detail_review_path") == "source_report_under_controlled_review", "evidence_handling_policy.raw_detail_review_path must be source_report_under_controlled_review")
    require(evidence_policy.get("raw_detail_reason_code_required") is True, "evidence_handling_policy.raw_detail_reason_code_required must be true")
    require(evidence_policy.get("allowed_raw_detail_reason_codes") == ["validate-pattern", "resolve-ambiguity", "audit-safety"], "evidence_handling_policy.allowed_raw_detail_reason_codes must be validate-pattern, resolve-ambiguity, audit-safety")

    window = artifact.get("sample_window")
    require(isinstance(window, dict), "sample_window must be an object")
    require(isinstance(window.get("source_count"), int) and window["source_count"] >= 2, "sample_window.source_count must be at least 2")
    require_string(window.get("selection_rule"), "sample_window.selection_rule")

    patterns = artifact.get("cross_developer_patterns")
    require(isinstance(patterns, list), "cross_developer_patterns must be a list")
    for idx, pattern in enumerate(patterns):
        require(isinstance(pattern, dict), f"cross_developer_patterns[{idx}] must be an object")
        require_string(pattern.get("pattern_id"), f"cross_developer_patterns[{idx}].pattern_id")
        require_string(pattern.get("problem"), f"cross_developer_patterns[{idx}].problem")
