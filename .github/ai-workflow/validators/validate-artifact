        require(pattern.get("severity") in {"low", "medium", "high"}, f"cross_developer_patterns[{idx}].severity must be valid")
        require(pattern.get("implicated_component") in {"model", "system_prompt", "tool_permissions", "context_window_usage", "retrieval_strategy", "session_state", "hidden_summaries", "test_feedback", "user_workflow", "workflow_contract", "schema", "validator", "unknown"}, f"cross_developer_patterns[{idx}].implicated_component must be valid")
        validate_string_list(pattern.get("evidence_refs"), f"cross_developer_patterns[{idx}].evidence_refs", allow_empty=False)
        require(len(pattern["evidence_refs"]) >= 2, f"cross_developer_patterns[{idx}].evidence_refs must include at least 2 refs")
        require(isinstance(pattern.get("main_bundle_candidate"), bool), f"cross_developer_patterns[{idx}].main_bundle_candidate must be boolean")

    candidates = artifact.get("main_bundle_change_candidates")
    require(isinstance(candidates, list), "main_bundle_change_candidates must be a list")
