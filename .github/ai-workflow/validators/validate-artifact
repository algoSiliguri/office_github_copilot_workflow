        profile_mode = candidate.get("profile_mode")
        require(profile_mode in {"not_applicable", "passive_guidance"}, f"main_bundle_change_candidates[{idx}].profile_mode must be not_applicable or passive_guidance")
        metric_scope = candidate.get("metric_scope")
        require(metric_scope in {"core_metric", "profile_diagnostic_signal"}, f"main_bundle_change_candidates[{idx}].metric_scope must be core_metric or profile_diagnostic_signal")
        diagnostic_signal_id = candidate.get("diagnostic_signal_id")
