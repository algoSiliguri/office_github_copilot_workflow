#!/usr/bin/env python3
import json
import re
import sys
from pathlib import Path


ALLOWED_OPERATIONS = {"create", "modify", "delete"}
ALLOWED_QUICK_TASK_STATUS = {"PASS_QUICK", "FAIL", "ESCALATED_TO_FULL_WORKFLOW"}
ALLOWED_VERIFICATION_STATUS = {"VERIFIED", "VERIFIED_WITH_DEGRADATION", "FAILED", "BLOCKED"}
ALLOWED_REVIEW_STATUS = {"PASS", "PASS_WITH_DEGRADATION", "FAIL", "BLOCKED"}
TASK_ID_RE = re.compile(r"^TASK-\d{3}$")

EXPECTED_TUPLES = {
    "diagnosis.schema.v1": ("diagnose.v1", "diagnosis.schema.v1"),
    "grill.schema.v1": ("grill.v1", "grill.schema.v1"),
    "legacy-explore.schema.v1": ("legacy-explore.v1", "legacy-explore.schema.v1"),
    "quick-task.schema.v1": ("quick-task.v1", "quick-task.schema.v1"),
    "plan.schema.v1": ("write-plan.v1", "plan.schema.v1"),
    "context-packet.schema.v1": ("context-packet.v1", "context-packet.schema.v1"),
    "execution-checkpoint.schema.v1": ("execute-plan.v1", "execution-checkpoint.schema.v1"),
    "verification.schema.v1": ("verify.v1", "verification.schema.v1"),
    "review.schema.v1": ("review.v1", "review.schema.v1"),
    "task-manifest.schema.v1": (None, "task-manifest.schema.v1"),
    "evaluation.schema.v1": ("evaluate.v1", "evaluation.schema.v1"),
    "system-evaluation.schema.v1": ("evaluate-system.v1", "system-evaluation.schema.v1"),
    "fleet-evaluation.schema.v1": ("evaluate-fleet.v1", "fleet-evaluation.schema.v1"),
    "raw-source-review.schema.v1": ("evaluate-fleet.v1", "raw-source-review.schema.v1"),
}

ARTIFACT_REF_KEYS = [
    "diagnosis",
    "grill",
    "legacy_exploration",
    "plan",
    "context_packet",
    "execution",
    "verification",
    "review",
    "evaluation",
]

OUTCOME_REASON_CATEGORIES = {
    "scope_violation",
    "incorrect_implementation",
    "criteria_not_met",
    "verification_incomplete",
    "quality_issue",
    "other",
}


def fail(reason: str) -> int:
    print(f"FAIL: {reason}")
    return 1


def require(condition: bool, reason: str):
    if not condition:
        raise ValueError(reason)


def require_string(value, path: str):
    require(isinstance(value, str) and value.strip(), f"{path} must be a non-empty string")


def load_json(path_arg: str):
    path = Path(path_arg)
    require(path.exists(), f"artifact does not exist: {path}")
    with path.open() as handle:
        data = json.load(handle)
    require(isinstance(data, dict), "artifact must be a JSON object")
    return data


def validate_string_list(entries, path: str, allow_empty: bool = True):
    require(isinstance(entries, list), f"{path} must be a list")
    if not allow_empty:
        require(bool(entries), f"{path} must be non-empty")
    for idx, value in enumerate(entries):
        require_string(value, f"{path}[{idx}]")


def validate_file_entries(entries, path: str, allow_empty: bool = True):
    require(isinstance(entries, list), f"{path} must be a list")
    if not allow_empty:
        require(bool(entries), f"{path} must be non-empty")
    for idx, entry in enumerate(entries):
        require(isinstance(entry, dict), f"{path}[{idx}] must be an object")
        require_string(entry.get("path"), f"{path}[{idx}].path")
        require(entry.get("operation") in ALLOWED_OPERATIONS, f"{path}[{idx}].operation must be one of {sorted(ALLOWED_OPERATIONS)}")


def validate_reason(reason, path: str):
    require(isinstance(reason, dict), f"{path} must be an object")
    require(reason.get("category") in OUTCOME_REASON_CATEGORIES, f"{path}.category must be a supported category")
    require_string(reason.get("details"), f"{path}.details")


def validate_validated_under(artifact):
    schema_version = artifact.get("schema_version")
    require(schema_version in EXPECTED_TUPLES, f"unsupported schema_version: {schema_version!r}")
    expected_command, expected_schema = EXPECTED_TUPLES[schema_version]
    vu = artifact.get("validated_under")
    require(isinstance(vu, dict), "validated_under must be an object")
    require(vu.get("workflow_manifest_version") == 1, "validated_under.workflow_manifest_version must be 1")
    require(vu.get("workflow_contract_version") == 1, "validated_under.workflow_contract_version must be 1")
    if expected_command is not None:
        require(vu.get("command_contract_id") == expected_command, f"validated_under.command_contract_id must be {expected_command}")
    require(isinstance(vu.get("command_contract_version"), int), "validated_under.command_contract_version must be an integer")
    require(vu.get("artifact_schema") == expected_schema, f"validated_under.artifact_schema must be {expected_schema}")
    require(vu.get("config_instruction_version") == "v1", "validated_under.config_instruction_version must be v1")


def validate_common(artifact, expected_type: str):
    require(artifact.get("artifact_type") == expected_type, f"artifact_type must be {expected_type}")
    require_string(artifact.get("task_id"), "task_id")
    require(TASK_ID_RE.match(artifact["task_id"]) is not None, "task_id must match TASK-{NNN}")
    if "created_at" in artifact:
        require_string(artifact.get("created_at"), "created_at")


def validate_grill(artifact):
    validate_common(artifact, "GrillRecord")
    require(artifact.get("task_type") in {"feature", "bugfix", "system_improvement", "exploration"}, "task_type must be valid")
    require(artifact.get("primary_surface") in {"copilot_plugin", "copilot_cli"}, "primary_surface must be copilot_plugin or copilot_cli")
    require_string(artifact.get("goal"), "goal")
    require_string(artifact.get("problem_statement"), "problem_statement")
    source_diagnosis = artifact.get("source_diagnosis")
    require(source_diagnosis is None or (isinstance(source_diagnosis, str) and source_diagnosis.strip()), "source_diagnosis must be null or non-empty string")
    validate_string_list(artifact.get("assumptions", []), "assumptions")
    questions = artifact.get("questions", [])
    require(isinstance(questions, list), "questions must be a list")
    for idx, question in enumerate(questions):
        require(isinstance(question, dict), f"questions[{idx}] must be an object")
        require_string(question.get("question"), f"questions[{idx}].question")
        require_string(question.get("answer"), f"questions[{idx}].answer")
    validate_string_list(artifact.get("risks", []), "risks")
    validate_string_list(artifact.get("constraints", []), "constraints")
    approach = artifact.get("approach")
    require(isinstance(approach, list) and approach, "approach must be a non-empty list")
    for idx, item in enumerate(approach):
        require(isinstance(item, dict), f"approach[{idx}] must be an object")
        require_string(item.get("decision"), f"approach[{idx}].decision")
        require_string(item.get("rationale"), f"approach[{idx}].rationale")
        validate_string_list(item.get("alternatives_rejected"), f"approach[{idx}].alternatives_rejected")
    require(isinstance(artifact.get("exploration_required"), bool), "exploration_required must be boolean")
    validate_string_list(artifact.get("exploration_reasons"), "exploration_reasons")
    decision = artifact.get("decision")
    require(decision in {"proceed", "stop"}, "decision must be proceed or stop")
    if decision == "proceed":
        criteria = artifact.get("success_criteria")
        require(isinstance(criteria, list) and criteria, "success_criteria must be a non-empty list")
        for idx, criterion in enumerate(criteria):
            require(isinstance(criterion, dict), f"success_criteria[{idx}] must be an object")
            require_string(criterion.get("id"), f"success_criteria[{idx}].id")
            require_string(criterion.get("description"), f"success_criteria[{idx}].description")
            require(criterion.get("verification_type") in {"command", "inspection", "log", "metric"}, f"success_criteria[{idx}].verification_type must be valid")
            if criterion.get("verification_type") == "command":
                require_string(criterion.get("verification_command"), f"success_criteria[{idx}].verification_command")
            require_string(criterion.get("expected_signal"), f"success_criteria[{idx}].expected_signal")
            require(criterion.get("observable") is True, f"success_criteria[{idx}].observable must be true")
    if decision == "stop":
        validate_string_list(artifact.get("open_blockers"), "open_blockers", allow_empty=False)
    if artifact.get("task_type") == "system_improvement":
        triggered_by = artifact.get("triggered_by")
        require(isinstance(triggered_by, dict), "triggered_by must be an object for system_improvement")
        require_string(triggered_by.get("source_type"), "triggered_by.source_type")
        validate_string_list(triggered_by.get("evaluation_refs"), "triggered_by.evaluation_refs", allow_empty=False)
        require(triggered_by.get("failure_category") in OUTCOME_REASON_CATEGORIES, "triggered_by.failure_category must be valid")


def validate_diagnosis(artifact):
    validate_common(artifact, "DiagnosisRecord")
    require(artifact.get("task_type") == "bugfix", "task_type must be bugfix")
    require(artifact.get("primary_surface") in {"copilot_plugin", "copilot_cli"}, "primary_surface must be valid")
    for key in ("bug_summary", "reported_behavior", "expected_behavior", "minimal_case", "suspected_root_cause"):
        require_string(artifact.get(key), key)
    reproduction = artifact.get("reproduction")
    require(isinstance(reproduction, dict), "reproduction must be an object")
    require_string(reproduction.get("command"), "reproduction.command")
    require_string(reproduction.get("output"), "reproduction.output")
    require(isinstance(reproduction.get("reproduced"), bool), "reproduction.reproduced must be boolean")
    hypotheses = artifact.get("hypotheses")
    require(isinstance(hypotheses, list) and hypotheses, "hypotheses must be a non-empty list")
    confirmed = 0
    for idx, hypothesis in enumerate(hypotheses):
        require(isinstance(hypothesis, dict), f"hypotheses[{idx}] must be an object")
        for key in ("id", "summary", "prediction", "evidence"):
            require_string(hypothesis.get(key), f"hypotheses[{idx}].{key}")
        require(hypothesis.get("status") in {"confirmed", "rejected", "untested"}, f"hypotheses[{idx}].status must be valid")
        if hypothesis.get("status") == "confirmed":
            confirmed += 1
    validate_file_entries(artifact.get("recommended_files_in_scope"), "recommended_files_in_scope", allow_empty=False)
    validate_string_list(artifact.get("recommended_files_out_of_scope", []), "recommended_files_out_of_scope")
    test_surface = artifact.get("test_surface")
    require(isinstance(test_surface, dict), "test_surface must be an object")
    require(test_surface.get("quality") in {"low", "medium", "high"}, "test_surface.quality must be valid")
    require_string(test_surface.get("recommended_regression_test"), "test_surface.recommended_regression_test")
    require(artifact.get("confidence") in {"low", "medium", "high"}, "confidence must be valid")
    decision = artifact.get("decision")
    require(decision in {"proceed", "blocked"}, "decision must be proceed or blocked")
    if decision == "proceed":
        require(reproduction.get("reproduced") is True, "decision=proceed requires reproduction.reproduced=true")
        require(confirmed >= 1, "decision=proceed requires at least one confirmed hypothesis")
    if decision == "blocked":
        validate_string_list(artifact.get("open_blockers"), "open_blockers", allow_empty=False)


def validate_legacy_explore(artifact):
    validate_common(artifact, "LegacyExplorationRecord")
    require_string(artifact.get("source_grill"), "source_grill")
    validate_string_list(artifact.get("trigger_reasons"), "trigger_reasons", allow_empty=False)
    validate_string_list(artifact.get("files_reviewed"), "files_reviewed", allow_empty=False)
    validate_string_list(artifact.get("modules_reviewed", []), "modules_reviewed")
    require_string(artifact.get("summary"), "summary")
    validate_string_list(artifact.get("findings", []), "findings")
    validate_string_list(artifact.get("risks", []), "risks")
    validate_file_entries(artifact.get("recommended_files_in_scope"), "recommended_files_in_scope", allow_empty=False)
    validate_string_list(artifact.get("recommended_files_out_of_scope", []), "recommended_files_out_of_scope")
    blast_radius = artifact.get("blast_radius")
    require(isinstance(blast_radius, dict), "blast_radius must be an object")
    for key in ("affected_files", "affected_modules", "caller_count"):
        require(key in blast_radius, f"blast_radius.{key} is required")
    require(blast_radius.get("confidence") in {"low", "medium", "high"}, "blast_radius.confidence must be valid")
    require(artifact.get("test_surface_quality") in {"low", "medium", "high"}, "test_surface_quality must be valid")
    require(isinstance(artifact.get("has_generated_code"), bool), "has_generated_code must be boolean")
    require(isinstance(artifact.get("has_stored_procedures"), bool), "has_stored_procedures must be boolean")
    validate_string_list(artifact.get("planning_constraints", []), "planning_constraints")
    decision = artifact.get("decision")
    require(decision in {"proceed", "stop"}, "decision must be proceed or stop")
    if decision == "stop":
        validate_string_list(artifact.get("open_blockers"), "open_blockers", allow_empty=False)


def validate_quick_task(artifact):
    validate_common(artifact, "QuickTaskRecord")
    require(artifact.get("primary_surface") in {"copilot_plugin", "copilot_cli"}, "primary_surface must be valid")
    require_string(artifact.get("task_summary"), "task_summary")
    files = artifact.get("files")
    require(isinstance(files, dict), "files must be an object")
    validate_file_entries(files.get("planned"), "files.planned", allow_empty=False)
    validate_file_entries(files.get("actual"), "files.actual")
    planned = {entry["path"] for entry in files["planned"]}
    actual = {entry["path"] for entry in files["actual"]}
    require(actual.issubset(planned), "files.actual must be a subset of files.planned")
    change_class = artifact.get("change_class")
    require(isinstance(change_class, dict), "change_class must be an object")
    require_string(change_class.get("value"), "change_class.value")
    require(isinstance(change_class.get("policy_allowed"), bool), "change_class.policy_allowed must be boolean")
    require(change_class.get("classification_status") in {"proposed", "revised_before_edit", "locked_for_execution"}, "change_class.classification_status must be valid")
    require(isinstance(change_class.get("public_behavior_change"), bool), "change_class.public_behavior_change must be boolean")
    bypass = artifact.get("bypass_justification")
    require(isinstance(bypass, dict), "bypass_justification must be an object")
    for key in ("retrieval_decision", "tdd_decision", "evaluation_decision"):
        entry = bypass.get(key)
        require(isinstance(entry, dict), f"bypass_justification.{key} must be an object")
        require(entry.get("bypassed") is True, f"bypass_justification.{key}.bypassed must be true")
        require_string(entry.get("reason"), f"bypass_justification.{key}.reason")
    verification = artifact.get("verification")
    require(isinstance(verification, dict), "verification must be an object")
    require_string(verification.get("command"), "verification.command")
    validate_string_list(verification.get("evidence"), "verification.evidence")
    require(isinstance(artifact.get("escalation_triggered"), bool), "escalation_triggered must be boolean")
    validate_string_list(artifact.get("escalation_reason"), "escalation_reason")
    status = artifact.get("status")
    require(status in ALLOWED_QUICK_TASK_STATUS, f"status must be one of {sorted(ALLOWED_QUICK_TASK_STATUS)}")
    if artifact.get("escalation_triggered"):
        require(status == "ESCALATED_TO_FULL_WORKFLOW", "escalation_triggered=true requires ESCALATED_TO_FULL_WORKFLOW")
        require(bool(artifact.get("escalation_reason")), "escalation requires escalation_reason")


def validate_plan(artifact):
    validate_common(artifact, "PlanArtifact")
    require(artifact.get("primary_surface") in {"copilot_plugin", "copilot_cli"}, "primary_surface must be valid")
    require_string(artifact.get("source_grill"), "source_grill")
    source_exploration = artifact.get("source_exploration")
    require(source_exploration is None or (isinstance(source_exploration, str) and source_exploration.strip()), "source_exploration must be null or non-empty string")
    gate = artifact.get("diagnosis_confidence_gate")
    require(isinstance(gate, dict), "diagnosis_confidence_gate must be an object")
    require(isinstance(gate.get("applies"), bool), "diagnosis_confidence_gate.applies must be boolean")
    require(gate.get("source_diagnosis") is None or (isinstance(gate.get("source_diagnosis"), str) and gate.get("source_diagnosis").strip()), "diagnosis_confidence_gate.source_diagnosis must be null or non-empty string")
    require(gate.get("confidence") in {"low", "medium", "high", "not_applicable"}, "diagnosis_confidence_gate.confidence must be valid")
    require(gate.get("planning_mode") in {"production_fix", "reproduction_test", "instrumentation", "test_surface_improvement", "not_applicable"}, "diagnosis_confidence_gate.planning_mode must be valid")
    require(gate.get("decision") in {"allowed", "blocked"}, "diagnosis_confidence_gate.decision must be allowed or blocked")
    require_string(gate.get("reason"), "diagnosis_confidence_gate.reason")
    if gate.get("confidence") == "low" and gate.get("planning_mode") == "production_fix":
        require(gate.get("decision") == "blocked", "low-confidence diagnosis blocks production_fix planning")
    if gate.get("decision") == "blocked":
        require(gate.get("planning_mode") == "production_fix", "blocked diagnosis gate is only valid for production_fix planning")
    validate_file_entries(artifact.get("files_in_scope"), "files_in_scope", allow_empty=False)
    validate_string_list(artifact.get("files_out_of_scope", []), "files_out_of_scope")
    retrieval_decision = artifact.get("retrieval_decision")
    require(isinstance(retrieval_decision, dict), "retrieval_decision must be an object")
    require(retrieval_decision.get("decision") in {"used", "skipped", "unavailable"}, "retrieval_decision.decision must be valid")
    validate_string_list(retrieval_decision.get("reasons"), "retrieval_decision.reasons", allow_empty=False)
    validate_string_list(retrieval_decision.get("files_considered"), "retrieval_decision.files_considered")
    require(isinstance(artifact.get("context_packet_required"), bool), "context_packet_required must be boolean")
    context_packet_path = artifact.get("context_packet_path")
    if artifact["context_packet_required"]:
        require_string(context_packet_path, "context_packet_path")
    tdd_decision = artifact.get("tdd_decision")
    require(isinstance(tdd_decision, dict), "tdd_decision must be an object")
    require(isinstance(tdd_decision.get("required"), bool), "tdd_decision.required must be boolean")
    require_string(tdd_decision.get("reason"), "tdd_decision.reason")
    validate_string_list(tdd_decision.get("test_first_plan"), "tdd_decision.test_first_plan")
    if tdd_decision["required"]:
        validate_string_list(tdd_decision.get("test_first_plan"), "tdd_decision.test_first_plan", allow_empty=False)
    scope_paths = {entry["path"] for entry in artifact["files_in_scope"]}
    steps = artifact.get("steps")
    require(isinstance(steps, list) and steps, "steps must be a non-empty list")
    for idx, step in enumerate(steps):
        require(isinstance(step, dict), f"steps[{idx}] must be an object")
        for key in ("id", "summary", "verification_command", "risk_reason"):
            require_string(step.get(key), f"steps[{idx}].{key}")
        require(step.get("preferred_surface") in {"copilot_plugin", "copilot_cli"}, f"steps[{idx}].preferred_surface must be valid")
        validate_file_entries(step.get("files"), f"steps[{idx}].files")
        for fidx, entry in enumerate(step.get("files", [])):
            require(entry["path"] in scope_paths, f"steps[{idx}].files[{fidx}].path must be in files_in_scope")
        validate_string_list(step.get("allowed_cli_commands"), f"steps[{idx}].allowed_cli_commands")
        require(step.get("risk_class") in {"safe", "degraded", "high-risk"}, f"steps[{idx}].risk_class must be valid")
        require(isinstance(step.get("requires_human_ack"), bool), f"steps[{idx}].requires_human_ack must be boolean")
        validate_string_list(step.get("depends_on"), f"steps[{idx}].depends_on")
        if step.get("risk_class") == "safe":
            require(step.get("requires_human_ack") is False, f"steps[{idx}] with risk_class safe must not require human ack")
        else:
            require(step.get("requires_human_ack") is True, f"steps[{idx}] with risk_class {step.get('risk_class')} must require human ack")
        if step.get("preferred_surface") == "copilot_cli":
            require(bool(step.get("allowed_cli_commands")), f"steps[{idx}] with preferred_surface=copilot_cli must declare allowed_cli_commands")
    require_string(artifact.get("verification_command"), "verification_command")
    validate_string_list(artifact.get("constraints", []), "constraints")


def validate_context_packet(artifact):
    validate_common(artifact, "ContextPacketArtifact")
    require_string(artifact.get("phase_id"), "phase_id")
    require_string(artifact.get("source_plan"), "source_plan")
    require_string(artifact.get("generated_at"), "generated_at")
    for key in ("scope", "retrieval_policy", "coverage", "execution_decision", "validation"):
        require(isinstance(artifact.get(key), dict), f"{key} must be an object")
    require(isinstance(artifact.get("included_context"), list), "included_context must be a list")


def validate_execution(artifact):
    validate_common(artifact, "ExecutionRecord")
    require(artifact.get("primary_surface") in {"copilot_plugin", "copilot_cli"}, "primary_surface must be valid")
    require_string(artifact.get("source_plan"), "source_plan")
    validate_string_list(artifact.get("step_ids"), "step_ids", allow_empty=False)
    status = artifact.get("status")
    require(status in {"in_progress", "completed", "blocked", "escalated"}, "status must be valid")
    plan_scope = artifact.get("plan_scope")
    require(isinstance(plan_scope, dict), "plan_scope must be an object")
    validate_string_list(plan_scope.get("files_authorized"), "plan_scope.files_authorized", allow_empty=False)
    actual_changes = artifact.get("actual_changes")
    require(isinstance(actual_changes, dict), "actual_changes must be an object")
    validate_string_list(actual_changes.get("files_touched"), "actual_changes.files_touched")
    validate_string_list(actual_changes.get("unplanned_files_touched"), "actual_changes.unplanned_files_touched")
    tdd_execution = artifact.get("tdd_execution")
    require(isinstance(tdd_execution, dict), "tdd_execution must be an object")
    require(isinstance(tdd_execution.get("required"), bool), "tdd_execution.required must be boolean")
    require(isinstance(tdd_execution.get("used"), bool), "tdd_execution.used must be boolean")
    validate_string_list(tdd_execution.get("evidence"), "tdd_execution.evidence")
    deviation_reason = tdd_execution.get("deviation_reason")
    require(deviation_reason is None or (isinstance(deviation_reason, str) and deviation_reason.strip()), "tdd_execution.deviation_reason must be null or non-empty string")
    if tdd_execution["required"]:
        require(tdd_execution["used"] is True, "tdd_execution.used must be true when TDD was required")
        validate_string_list(tdd_execution.get("evidence"), "tdd_execution.evidence", allow_empty=False)
    cli_handoff = artifact.get("cli_handoff")
    require(isinstance(cli_handoff, dict), "cli_handoff must be an object")
    require(cli_handoff.get("approval_status") in {"not_required", "pending", "approved", "rejected"}, "cli_handoff.approval_status must be valid")
    require_string(cli_handoff.get("reason"), "cli_handoff.reason")
    validate_string_list(cli_handoff.get("allowed_commands"), "cli_handoff.allowed_commands")
    validate_string_list(cli_handoff.get("allowed_files"), "cli_handoff.allowed_files")
    validate_string_list(cli_handoff.get("blocked_actions"), "cli_handoff.blocked_actions")
    require_string(cli_handoff.get("expected_return_artifact"), "cli_handoff.expected_return_artifact")
    human_acks = artifact.get("human_acknowledgments")
    require(isinstance(human_acks, list), "human_acknowledgments must be a list")
    for idx, ack in enumerate(human_acks):
        require(isinstance(ack, dict), f"human_acknowledgments[{idx}] must be an object")
        require_string(ack.get("step_id"), f"human_acknowledgments[{idx}].step_id")
        require(ack.get("status") in {"pending", "approved", "rejected"}, f"human_acknowledgments[{idx}].status must be valid")
        require_string(ack.get("reviewer"), f"human_acknowledgments[{idx}].reviewer")
        require_string(ack.get("reason"), f"human_acknowledgments[{idx}].reason")
    commands_run = artifact.get("commands_run")
    require(isinstance(commands_run, list), "commands_run must be a list")
    for idx, cmd in enumerate(commands_run):
        require(isinstance(cmd, dict), f"commands_run[{idx}] must be an object")
        require_string(cmd.get("command"), f"commands_run[{idx}].command")
        require_string(cmd.get("output"), f"commands_run[{idx}].output")
    decision = artifact.get("decision")
    require(isinstance(decision, dict), "decision must be an object")
    require(decision.get("status") in {"continue", "stop", "escalate"}, "decision.status must be continue, stop, or escalate")
    require_string(decision.get("reason"), "decision.reason")
    unplanned = actual_changes.get("unplanned_files_touched", [])
    if unplanned:
        require(status in {"blocked", "escalated"}, "unplanned_files_touched requires blocked or escalated execution status")
        require(decision.get("status") == "escalate", "unplanned_files_touched requires decision.status=escalate")


def validate_verification(artifact):
