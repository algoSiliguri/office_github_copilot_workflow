#!/usr/bin/env python3
"""Validate canonical task artifact placement.

Usage: validate-artifact-path <artifact_file_path>
Exit 0 = valid, Exit 1 = violation
"""

import json
import re
import sys
from pathlib import Path


RUNTIME_ROOT = Path(".github/tasks")
TASK_ID_RE = re.compile(r"^TASK-\d{3}$")
AUTHORITATIVE_FILENAMES = {
    "DiagnosisRecord": "diagnosis.json",
    "GrillRecord": "grill.json",
    "LegacyExplorationRecord": "legacy-exploration.json",
    "PlanArtifact": "plan.json",
    "ContextPacketArtifact": "context-packet.json",
    "ExecutionRecord": "execution.json",
    "VerificationRecord": "verification.json",
    "ReviewRecord": "review.json",
    "EvaluationRecord": "evaluation.json",
    "SystemEvaluationReport": "system-evaluation.json",
    "FleetEvaluationReport": "fleet-evaluation.json",
    "RawSourceReviewRecord": "raw-source-review.json",
    "TaskManifest": "task-manifest.json",
    "QuickTaskRecord": "quick-task.json",
}


def fail(reason: str) -> int:
    print(f"ERROR: {reason}", file=sys.stderr)
    return 1


def main() -> int:
    artifact_arg = sys.argv[1] if len(sys.argv) > 1 else ""
    if not artifact_arg:
        return fail("artifact file path required")

    artifact_file = Path(artifact_arg)
    if not artifact_file.is_file():
        return fail(f"file not found: {artifact_file}")

    try:
        with artifact_file.open() as handle:
            data = json.load(handle)
    except Exception as exc:
        return fail(f"cannot parse JSON from {artifact_file}: {exc}")

    artifact_type = data.get("artifact_type")
    if artifact_type == "SystemEvaluationReport":
        evaluation_id = data.get("evaluation_id")
        if not evaluation_id:
            return fail(f"cannot read evaluation_id from {artifact_file}")
        if not re.match(r"^SYS-EVAL-\d{8}-\d{6}$", evaluation_id):
            return fail(f"evaluation_id must match SYS-EVAL-YYYYMMDD-HHMMSS: {evaluation_id}")
        if artifact_file.is_absolute():
            try:
                relative_path = artifact_file.resolve().relative_to(Path.cwd().resolve())
            except ValueError:
                relative_path = artifact_file
        else:
            relative_path = artifact_file
        normalized = Path(*[part for part in relative_path.parts if part != "."])
        expected = Path(".github/tasks/system-evaluations") / evaluation_id / "system-evaluation.json"
        if normalized != expected:
            return fail(f"SystemEvaluationReport must live at {expected} but found {normalized}")
        print(f"OK: SystemEvaluationReport path valid ({normalized})")
        return 0

    if artifact_type == "FleetEvaluationReport":
        evaluation_id = data.get("fleet_evaluation_id")
        if not evaluation_id:
            return fail(f"cannot read fleet_evaluation_id from {artifact_file}")
        if not re.match(r"^FLEET-EVAL-\d{8}-\d{6}$", evaluation_id):
            return fail(f"fleet_evaluation_id must match FLEET-EVAL-YYYYMMDD-HHMMSS: {evaluation_id}")
        if artifact_file.is_absolute():
            try:
                relative_path = artifact_file.resolve().relative_to(Path.cwd().resolve())
            except ValueError:
                relative_path = artifact_file
        else:
            relative_path = artifact_file
        normalized = Path(*[part for part in relative_path.parts if part != "."])
        expected = Path(".github/tasks/fleet-evaluations") / evaluation_id / "fleet-evaluation.json"
        if normalized != expected:
            return fail(f"FleetEvaluationReport must live at {expected} but found {normalized}")
        print(f"OK: FleetEvaluationReport path valid ({normalized})")
        return 0

    if artifact_type == "RawSourceReviewRecord":
        review_id = data.get("review_id")
        source_fleet_evaluation = data.get("source_fleet_evaluation")
        if not review_id:
            return fail(f"cannot read review_id from {artifact_file}")
        if not re.match(r"^RAW-SOURCE-REVIEW-\d{8}-\d{6}$", review_id):
            return fail(f"review_id must match RAW-SOURCE-REVIEW-YYYYMMDD-HHMMSS: {review_id}")
        if not source_fleet_evaluation:
            return fail(f"cannot read source_fleet_evaluation from {artifact_file}")
        if not re.match(r"^FLEET-EVAL-\d{8}-\d{6}$", source_fleet_evaluation):
            return fail(f"source_fleet_evaluation must match FLEET-EVAL-YYYYMMDD-HHMMSS: {source_fleet_evaluation}")
        if artifact_file.is_absolute():
            try:
                relative_path = artifact_file.resolve().relative_to(Path.cwd().resolve())
            except ValueError:
                relative_path = artifact_file
        else:
            relative_path = artifact_file
        normalized = Path(*[part for part in relative_path.parts if part != "."])
        expected = Path(".github/tasks/fleet-evaluations") / source_fleet_evaluation / "raw-source-reviews" / review_id / "raw-source-review.json"
        if normalized != expected:
            return fail(f"RawSourceReviewRecord must live at {expected} but found {normalized}")
        print(f"OK: RawSourceReviewRecord path valid ({normalized})")
        return 0

    task_id = data.get("task_id")
    if not artifact_type:
        return fail(f"cannot read artifact_type from {artifact_file}")
    if not task_id:
        return fail(f"cannot read task_id from {artifact_file}")
    if not TASK_ID_RE.match(task_id):
        return fail(f"task_id must match TASK-{{NNN}}: {task_id}")

    expected_filename = AUTHORITATIVE_FILENAMES.get(artifact_type)
    if not expected_filename:
        print(f"WARN: unknown artifact_type '{artifact_type}' — skipping path check", file=sys.stderr)
        return 0

    if artifact_file.is_absolute():
        try:
            relative_path = artifact_file.resolve().relative_to(Path.cwd().resolve())
        except ValueError:
            relative_path = artifact_file
    else:
        relative_path = artifact_file

    normalized = Path(*[part for part in relative_path.parts if part != "."])
    parts = normalized.parts
    if len(parts) < 3 or parts[0:2] != (".github", "tasks"):
        return fail(f"{artifact_type} must live under {RUNTIME_ROOT} but found {normalized}")

    folder_task_id = parts[2]
    if folder_task_id != task_id:
        return fail(f"folder task_id {folder_task_id} does not match artifact task_id {task_id}")
    if not TASK_ID_RE.match(folder_task_id):
        return fail(f"task folder must match TASK-{{NNN}} but found {folder_task_id}")

    if len(parts) == 4:
        if parts[3] != expected_filename:
            return fail(f"{artifact_type} must use filename {expected_filename} but found {parts[3]}")
        print(f"OK: {artifact_type} path valid ({normalized})")
        return 0

    if len(parts) >= 6 and parts[3] == "attempts":
        if artifact_file.suffix != ".json":
            return fail("attempt history artifacts must be .json")
        if parts[-1] == expected_filename:
            return fail("attempt history files must use timestamped names, not authoritative filenames")
        print(f"OK: {artifact_type} historical attempt path valid ({normalized})")
        return 0

    return fail(f"{artifact_type} is misplaced: {normalized}")


if __name__ == "__main__":
    sys.exit(main())
