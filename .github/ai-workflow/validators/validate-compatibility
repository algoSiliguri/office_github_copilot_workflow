#!/usr/bin/env python3
import sys
from pathlib import Path

import yaml


EXPECTED_TUPLES = {
    "grill.schema.v1": ("grill.v1", "grill.schema.v1"),
    "legacy-explore.schema.v1": ("legacy-explore.v1", "legacy-explore.schema.v1"),
    "quick-task.schema.v1": ("quick-task.v1", "quick-task.schema.v1"),
    "plan.schema.v1": ("write-plan.v1", "plan.schema.v1"),
    "context-packet.schema.v1": ("context-packet.v1", "context-packet.schema.v1"),
    "execution-checkpoint.schema.v1": ("execute-plan.v1", "execution-checkpoint.schema.v1"),
    "verification.schema.v1": ("verify.v1", "verification.schema.v1"),
    "review.schema.v1": ("review.v1", "review.schema.v1"),
}


def emit(status: str, reason: str) -> int:
    print(f"{status}: {reason}")
    return 0 if status != "FAIL" else 1


def main() -> int:
    if len(sys.argv) != 2:
        return emit("FAIL", "usage: validate-compatibility <artifact-path>")

    path = Path(sys.argv[1])
    if not path.exists():
        return emit("FAIL", f"missing artifact: {path}")

    try:
        artifact = yaml.safe_load(path.read_text())
        manifest = yaml.safe_load(Path(".github/ai-workflow/manifest.yaml").read_text())
        config = yaml.safe_load(Path(".github/workflow/config.yaml").read_text())
    except Exception as exc:
        return emit("FAIL", f"unable to read compatibility inputs: {exc}")

    validated = artifact.get("validated_under")
    if not isinstance(validated, dict):
        return emit("FAIL", "artifact missing validated_under")

    schema_version = artifact.get("schema_version")
    expected = EXPECTED_TUPLES.get(schema_version)
    if expected is None:
        return emit("FAIL", f"unsupported schema_version: {schema_version!r}")

    expected_command, expected_schema = expected
    checks = [
        (validated.get("workflow_manifest_version") == manifest.get("manifest_version"), "workflow_manifest_version mismatch"),
        (validated.get("workflow_contract_version") == manifest.get("workflow_contract_version"), "workflow_contract_version mismatch"),
        (validated.get("command_contract_id") == expected_command, "command_contract_id mismatch"),
        (validated.get("command_contract_version") == 1, "command_contract_version mismatch"),
        (validated.get("artifact_schema") == expected_schema, "artifact_schema mismatch"),
        (validated.get("config_instruction_version") == config.get("workflow", {}).get("instruction_version"), "config_instruction_version mismatch"),
    ]
    for ok, reason in checks:
        if not ok:
            return emit("FAIL", reason)

    return emit("PASS", "artifact compatible with exact workflow/command/schema/config tuple")


if __name__ == "__main__":
    sys.exit(main())
