#!/usr/bin/env python3
import json
import sys
from pathlib import Path


def fail(reason: str) -> int:
    print(f"FAIL: {reason}")
    return 1


def main() -> int:
    if len(sys.argv) != 2:
        return fail("usage: validate-context-packet <artifact-path>")

    path = Path(sys.argv[1])
    if not path.exists():
        return fail(f"missing artifact: {path}")

    try:
        artifact = json.loads(path.read_text())
    except Exception as exc:
        return fail(f"unable to read artifact: {exc}")

    if not isinstance(artifact, dict):
        return fail("context packet must be a JSON object")

    if artifact.get("artifact_type") != "ContextPacketArtifact":
        return fail("artifact_type must be ContextPacketArtifact")

    decision = artifact.get("execution_decision", {})
    status = decision.get("status")
    allowed = {"proceed", "refresh_required", "escalate"}
    if status not in allowed:
        return fail(f"execution_decision.status must be one of {sorted(allowed)}")

    print("PASS")
    return 0


if __name__ == "__main__":
    sys.exit(main())
