#!/usr/bin/env python3
import json
import sys
from pathlib import Path


def fail(reason: str) -> int:
    print(f"ERROR: {reason}", file=sys.stderr)
    return 1


def main() -> int:
    if len(sys.argv) != 3:
        return fail("usage: validate-criteria-coverage <verification_file> <grill_file>")

    verification_path = Path(sys.argv[1])
    grill_path = Path(sys.argv[2])
    if not verification_path.is_file():
        return fail(f"verification file not found: {verification_path}")
    if not grill_path.is_file():
        return fail(f"grill file not found: {grill_path}")

    try:
        verification = json.loads(verification_path.read_text())
        grill = json.loads(grill_path.read_text())
    except Exception as exc:
        return fail(f"cannot parse JSON: {exc}")

    declared = grill.get("success_criteria", [])
    outcomes = verification.get("criteria_outcomes", [])
    if not declared:
        print("WARN: grill has no success_criteria — cannot validate coverage", file=sys.stderr)
        return 0
    if len(declared) != len(outcomes):
        return fail(f"criteria_outcomes count ({len(outcomes)}) != success_criteria count ({len(declared)})")

    declared_descriptions = [
        c.get("description", "") if isinstance(c, dict) else c
        for c in declared
    ]
    outcome_criteria = [entry.get("criterion") for entry in outcomes]
    if outcome_criteria != declared_descriptions:
        missing = [d for d in declared_descriptions if d not in outcome_criteria]
        extras = [o for o in outcome_criteria if o not in declared_descriptions]
        detail = []
        if missing:
            detail.append(f"missing={missing}")
        if extras:
            detail.append(f"unexpected={extras}")
        return fail("criteria_outcomes must map 1:1 to GrillRecord.success_criteria descriptions in declared order" + (f" ({'; '.join(detail)})" if detail else ""))

    print(f"OK: criteria coverage valid ({len(outcomes)}/{len(declared)} criteria covered)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
