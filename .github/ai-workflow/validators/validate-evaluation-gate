#!/usr/bin/env bash
# Validates an EvaluationRecord against evaluation gate rules.
# Usage: validate-evaluation-gate <evaluation_file>
# Exit 0 = valid, Exit 1 = violation

set -euo pipefail

EVALUATION_FILE="${1:-}"

if [[ -z "$EVALUATION_FILE" ]]; then
  echo "ERROR: evaluation file path required" >&2
  exit 1
fi

if [[ ! -f "$EVALUATION_FILE" ]]; then
  echo "ERROR: file not found: $EVALUATION_FILE" >&2
  exit 1
fi

python3 - "$EVALUATION_FILE" <<'PYEOF'
import json, sys

path = sys.argv[1]
with open(path) as f:
    ev = json.load(f)

errors = []

# Must be EvaluationRecord
if ev.get("artifact_type") != "EvaluationRecord":
    errors.append("artifact_type must be EvaluationRecord")

# evaluation_status must be valid
eval_status = ev.get("evaluation_status", "")
if eval_status not in ("draft", "confirmed", "overridden"):
    errors.append(f"evaluation_status '{eval_status}' not in [draft, confirmed, overridden]")

# overridden requires override_reason
if eval_status == "overridden":
    he = ev.get("human_evaluation", {})
    if not he.get("override_reason"):
        errors.append("evaluation_status=overridden requires human_evaluation.override_reason")
    else:
        reason = he["override_reason"]
        valid_categories = {"scope_violation", "incorrect_implementation", "criteria_not_met",
                            "verification_incomplete", "quality_issue", "other"}
        if reason.get("category") not in valid_categories:
            errors.append(f"override_reason.category '{reason.get('category')}' not valid")
        if not reason.get("details") or len(reason["details"]) < 10:
            errors.append("override_reason.details must be at least 10 characters")

# confirmed requires confirmed_at
if eval_status == "confirmed":
    he = ev.get("human_evaluation", {})
    if not he.get("confirmed_at"):
        errors.append("evaluation_status=confirmed requires human_evaluation.confirmed_at")
    if not he.get("reviewer"):
        errors.append("evaluation_status=confirmed requires human_evaluation.reviewer")

# criteria_satisfaction_rate in 0–1
scores = ev.get("scores", {})
rate = scores.get("criteria_satisfaction_rate")
if rate is not None and not (0.0 <= rate <= 1.0):
    errors.append(f"criteria_satisfaction_rate {rate} out of range 0.0–1.0")

# outcome must be valid
outcome = ev.get("outcome", "")
if outcome not in ("success", "partial_success", "failure"):
    errors.append(f"outcome '{outcome}' not in [success, partial_success, failure]")

if errors:
    for e in errors:
        print(f"ERROR: {e}", file=sys.stderr)
    sys.exit(1)

print(f"OK: EvaluationRecord valid (outcome={outcome}, status={eval_status})")
sys.exit(0)
PYEOF
