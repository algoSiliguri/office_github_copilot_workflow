#!/usr/bin/env python3
import json
import sys
from pathlib import Path

import yaml


QUICK_TASK_POLICY_PATH = Path(".github/ai-workflow/policies/quick-task-policy.v1.yaml")
WILDCARD_CHARS = set("*?[]")


def fail(reason: str) -> int:
    print(f"FAIL: {reason}")
    return 1


def require(condition: bool, reason: str):
    if not condition:
        raise ValueError(reason)


def load_json(path: Path):
    data = json.loads(path.read_text())
    require(isinstance(data, dict), f"{path} must contain a JSON object")
    return data


def load_yaml(path: Path):
    data = yaml.safe_load(path.read_text())
    require(isinstance(data, dict), f"{path} must contain a YAML mapping")
    return data


def require_exact_path(path_value, path_label: str):
    require(isinstance(path_value, str) and path_value.strip(), f"{path_label} must be a non-empty string")
    require(not any(ch in path_value for ch in WILDCARD_CHARS), f"{path_label} must be exact")


def main() -> int:
    if len(sys.argv) != 2:
        return fail("usage: validate-plan-scope <artifact-path>")

    try:
        artifact = load_json(Path(sys.argv[1]))
        schema_version = artifact.get("schema_version")

        if schema_version == "quick-task.schema.v1":
            policy = load_yaml(QUICK_TASK_POLICY_PATH)
            planned = artifact["files"]["planned"]
            require(len(planned) <= policy["max_files"], f"planned file count exceeds max_files={policy['max_files']}")
            for idx, entry in enumerate(planned):
                require_exact_path(entry.get("path"), f"files.planned[{idx}].path")
            for idx, entry in enumerate(artifact["files"]["actual"]):
                require_exact_path(entry.get("path"), f"files.actual[{idx}].path")
            value = artifact["change_class"].get("value")
            require(isinstance(value, str) and value.strip(), "change_class.value must be declared")
            allowed = set(policy["allowed_change_classes"])
            forbidden = set(policy["forbidden_change_classes"])
            require(value in allowed or value in forbidden, "change_class.value must be present in quick-task policy")
            policy_allowed = artifact["change_class"].get("policy_allowed")
            require(isinstance(policy_allowed, bool), "change_class.policy_allowed must be boolean")
            if value in forbidden:
                require(policy_allowed is False, "forbidden change class must set policy_allowed=false")
                require(artifact.get("status") == "ESCALATED_TO_FULL_WORKFLOW", "forbidden change class must escalate")
            if value in allowed:
                require(policy_allowed is True, "allowed change class must set policy_allowed=true")
        elif schema_version == "plan.schema.v1":
            require(artifact.get("artifact_type") == "PlanArtifact", "artifact_type must be PlanArtifact")
            grill_path = artifact.get("source_grill")
            require(isinstance(grill_path, str) and grill_path.strip(), "source_grill must be a non-empty string")
            if Path(grill_path).exists():
                grill = load_json(Path(grill_path))
                require(grill.get("decision") == "proceed", "plan requires GrillRecord decision=proceed")
                if grill.get("exploration_required") is True:
                    source_exploration = artifact.get("source_exploration")
                    require(isinstance(source_exploration, str) and source_exploration.strip(), "source_exploration is required when GrillRecord requires exploration")
                    require(Path(source_exploration).exists(), "source_exploration artifact must exist when GrillRecord requires exploration")
                    explore = load_json(Path(source_exploration))
                    require(explore.get("decision") == "proceed", "LegacyExplorationRecord must have decision=proceed")
            if artifact.get("context_packet_required") is True:
                cp_path = artifact.get("context_packet_path")
                require(isinstance(cp_path, str) and cp_path.strip(), "context_packet_path must be declared when context_packet_required is true")
            scope_paths = {e["path"] for e in artifact.get("files_in_scope", []) if isinstance(e, dict)}
            for idx, path in enumerate(artifact.get("files_out_of_scope", [])):
                require_exact_path(path, f"files_out_of_scope[{idx}]")
            for idx, step in enumerate(artifact.get("steps", [])):
                for fidx, fentry in enumerate(step.get("files", [])):
                    if isinstance(fentry, dict):
                        fpath = fentry.get("path", "")
                        require(fpath in scope_paths, f"steps[{idx}].files[{fidx}].path '{fpath}' is not in files_in_scope")
                risk_class = step.get("risk_class")
                requires_ack = step.get("requires_human_ack")
                if risk_class in {"degraded", "high-risk"}:
                    require(requires_ack is True, f"steps[{idx}] with risk_class={risk_class} must require human ack")
                if risk_class == "safe":
                    require(requires_ack is False, "safe steps must not require human ack")
                if step.get("preferred_surface") == "copilot_cli":
                    require(bool(step.get("allowed_cli_commands")), f"steps[{idx}] with preferred_surface=copilot_cli must declare allowed_cli_commands")
        elif schema_version == "verification.schema.v1":
            command_run = artifact.get("verification_command_run")
            require(isinstance(command_run, str) and command_run.strip(), "verification_command_run must be a non-empty string")
            plan_ref = artifact.get("plan_ref")
            if plan_ref and Path(plan_ref).exists():
                plan_artifact = load_json(Path(plan_ref))
                plan_cmd = plan_artifact.get("verification_command")
                if plan_cmd:
                    require(command_run == plan_cmd, f"verification_command_run ('{command_run}') must exactly match plan.verification_command ('{plan_cmd}')")
            execution_ref = artifact.get("execution_ref")
            if execution_ref and Path(execution_ref).exists():
                execution_artifact = load_json(Path(execution_ref))
                authorized = set(execution_artifact["plan_scope"]["files_authorized"])
                touched = set(execution_artifact["actual_changes"]["files_touched"])
                require(touched.issubset(authorized), "execution actual_changes.files_touched must be subset of authorized plan scope")
        elif schema_version == "review.schema.v1":
            for idx, path in enumerate(artifact.get("actual_changed_files", [])):
                require_exact_path(path, f"actual_changed_files[{idx}]")
            if artifact.get("scope_violations"):
                require(artifact.get("status") == "FAIL", "scope violations require review status FAIL")
        else:
            raise ValueError("schema_version must be one of plan/verification/review/quick-task schema versions")

        print("PASS")
        return 0
    except ValueError as exc:
        return fail(str(exc))
    except Exception as exc:
        return fail(f"unexpected validation error: {exc}")


if __name__ == "__main__":
    sys.exit(main())
