#!/usr/bin/env python3
"""
validate-quick-task-preclassify  <artifact-path>

Pre-write gate for /quick-task. Must pass before the agent edits any file.

Checks:
  1. change_class.classification_status == "locked_for_execution"
  2. change_class.policy_allowed == True  (forbidden class must escalate, not edit)
  3. files.planned is non-empty with exact paths
"""
import sys
from pathlib import Path

import yaml


def fail(reason: str) -> int:
    print(f"FAIL: {reason}")
    return 1


def require(condition: bool, reason: str):
    if not condition:
        raise ValueError(reason)


def main() -> int:
    if len(sys.argv) != 2:
        return fail("usage: validate-quick-task-preclassify <artifact-path>")

    try:
        path = Path(sys.argv[1])
        if not path.exists():
            return fail(f"artifact not found: {path}")

        artifact = yaml.safe_load(path.read_text())
        require(isinstance(artifact, dict), "artifact must be a mapping")

        # Gate 1: classification must be locked before edits start
        change_class = artifact.get("change_class") or {}
        classification_status = change_class.get("classification_status")
        require(
            classification_status == "locked_for_execution",
            f"change_class.classification_status must be 'locked_for_execution' before editing "
            f"(got: {classification_status!r}) — confirm scope and set to 'locked_for_execution'",
        )

        # Gate 2: forbidden change class must not proceed to edits
        policy_allowed = change_class.get("policy_allowed")
        require(isinstance(policy_allowed, bool), "change_class.policy_allowed must be boolean")
        require(
            policy_allowed is True,
            "change_class.policy_allowed is false — task must ESCALATE_TO_FULL_WORKFLOW; "
            "do not edit files",
        )

        # Gate 3: planned files must be declared and exact before first edit
        files = artifact.get("files") or {}
        planned = files.get("planned") or []
        require(isinstance(planned, list) and planned, "files.planned must be non-empty before edits start")
        for idx, entry in enumerate(planned):
            require(isinstance(entry, dict), f"files.planned[{idx}] must be a mapping")
            path_val = entry.get("path", "")
            require(
                isinstance(path_val, str) and path_val.strip(),
                f"files.planned[{idx}].path must be a non-empty exact path",
            )
            require(
                "*" not in path_val and "?" not in path_val,
                f"files.planned[{idx}].path must be exact — no wildcards allowed",
            )

        print("PASS: quick-task pre-edit scope lock verified")
        return 0

    except ValueError as exc:
        return fail(str(exc))
    except Exception as exc:
        return fail(f"unexpected error: {exc}")


if __name__ == "__main__":
    sys.exit(main())
