def expect_pass(label: str, args):
    ok, output = run_check(args)
    if not ok:
        raise ValueError(f"{label} failed: {output}")
    print(f"PASS: {label}")


def expect_fail(label: str, args):
    ok, output = run_check(args)
    if ok:
        raise ValueError(f"{label} unexpectedly passed")
    print(f"PASS: {label} failed as expected")


def main() -> int:
    try:
        expect_pass("bootstrap", ["python3", ".github/ai-workflow/validators/bootstrap"])
        expect_pass("manifest", ["python3", ".github/ai-workflow/validators/validate-manifest"])
        expect_pass("config", ["python3", ".github/ai-workflow/validators/validate-config", ".github/workflow/config.yaml"])

        for schema_path in sorted(Path(".github/ai-workflow/schemas").glob("*.json")):
            expect_pass(f"schema parses {schema_path}", ["python3", "-m", "json.tool", str(schema_path)])

        for artifact_path in sorted(Path(".github/ai-workflow/artifacts/examples/valid").glob("**/*.json")):
            expect_pass(f"valid example {artifact_path}", ["python3", ".github/ai-workflow/validators/validate-artifact", str(artifact_path)])

        expect_pass("criteria-coverage", [
            "python3", ".github/ai-workflow/validators/validate-criteria-coverage",
            ".github/ai-workflow/artifacts/examples/valid/TASK-001/verification.json",
            ".github/ai-workflow/artifacts/examples/valid/TASK-001/grill.json",
        ])
        expect_pass("evaluation-gate", [
            "python3", ".github/ai-workflow/validators/validate-evaluation-gate",
            ".github/ai-workflow/artifacts/examples/valid/TASK-001/evaluation.json",
        ])

        with tempfile.TemporaryDirectory() as tmp:
            tmp_path = Path(tmp)

            fleet_valid = fleet_report()
            fleet_valid_path = tmp_path / "fleet-valid.json"
            write_json(fleet_valid_path, fleet_valid)
            expect_pass("synthetic fleet report", ["python3", ".github/ai-workflow/validators/validate-artifact", str(fleet_valid_path)])

            fleet_raw = fleet_report()
            fleet_raw["evidence_handling_policy"]["raw_excerpts_allowed"] = True
            fleet_raw_path = tmp_path / "fleet-raw-excerpts.json"
            write_json(fleet_raw_path, fleet_raw)
            expect_fail("fleet raw excerpts safety gate", ["python3", ".github/ai-workflow/validators/validate-artifact", str(fleet_raw_path)])

            fleet_no_reason = fleet_report()
            fleet_no_reason["evidence_handling_policy"].pop("raw_detail_reason_code_required")
            fleet_no_reason_path = tmp_path / "fleet-no-reason-code.json"
            write_json(fleet_no_reason_path, fleet_no_reason)
            expect_fail("fleet raw detail reason-code gate", ["python3", ".github/ai-workflow/validators/validate-artifact", str(fleet_no_reason_path)])

            raw_valid = raw_source_review()
            raw_valid_path = tmp_path / "raw-source-review-valid.json"
            write_json(raw_valid_path, raw_valid)
            expect_pass("synthetic raw source review", ["python3", ".github/ai-workflow/validators/validate-artifact", str(raw_valid_path)])

            raw_copied = raw_source_review()
            raw_copied["copied_raw_detail"] = True
            raw_copied_path = tmp_path / "raw-source-review-copied-detail.json"
            write_json(raw_copied_path, raw_copied)
            expect_fail("raw source copied-detail safety gate", ["python3", ".github/ai-workflow/validators/validate-artifact", str(raw_copied_path)])

        readme = Path(".github/README.md").read_text()
        for required in [
            "ready for V1 local/plugin use",
            "not self-modifying",
            "validate-release-readiness",
        ]:
            if required not in readme:
                raise ValueError(f"README missing release-readiness statement: {required}")

        print("PASS: V1 release readiness gate")
        return 0
    except ValueError as exc:
        return fail(str(exc))


if __name__ == "__main__":
    sys.exit(main())
