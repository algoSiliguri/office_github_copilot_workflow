{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/scripts/log-event.py",
        "powershell": "python3 .github/hooks/scripts/log-event.py",
        "env": {"COPILOT_HOOK_EVENT": "sessionStart"}
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/scripts/log-event.py",
        "powershell": "python3 .github/hooks/scripts/log-event.py",
        "env": {"COPILOT_HOOK_EVENT": "userPromptSubmitted"}
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/scripts/pre-tool-use.py",
        "powershell": "python3 .github/hooks/scripts/pre-tool-use.py"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/scripts/post-tool-use.py",
        "powershell": "python3 .github/hooks/scripts/post-tool-use.py"
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/scripts/agent-stop.py",
        "powershell": "python3 .github/hooks/scripts/agent-stop.py"
      }
    ]
  }
}
