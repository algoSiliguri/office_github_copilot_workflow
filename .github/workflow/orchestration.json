{
  "schema_version": "orchestration.schema.v2",
  "phase_order": ["setup", "grill", "plan", "execute", "verify"],
  "approval_kinds": ["plan", "grill", "requirements", "graph-degraded", "scope-drift", "memory-write", "governance-edit"],

  "setup_contract": {
    "validate_bundle_layout": true,
    "target_agents_managed_block_only": true,
    "graph_record_required": true,
    "graph_provider": "graphify",
    "required_graph_outputs": [
      "graphify-out/graph.json",
      "graphify-out/GRAPH_REPORT.md",
      "graphify-out/manifest.json"
    ],
    "copilot_install_command": "graphify copilot install",
    "copilot_install_expected_not_guaranteed": true,
    "graph_regeneration_requires_approval": true,
    "graph_states": {
      "missing": "No graphify-out/ output is present.",
      "stale": "Graph metadata does not match the current branch, commit, or source hash.",
      "degraded-approved": "Graph output is missing or stale, and human approval permits degraded planning for this task.",
      "fresh": "Graph metadata matches the current branch and commit/source hash."
    }
  },

  "grill_contract": {
    "artifact": ".github/tasks/TASK-{NNN}/grill.json",
    "schema": ".github/workflow/schemas/grill-record.schema.json",
    "requires_graph_report_read": true,
    "human_approval_kind": "grill",
    "discovery_gate_required_before_plan": true,
    "impacted_files_must_be_nonempty": true,
    "mandatory_verification_steps_must_be_nonempty": true,
    "requirements_ref_optional": true
  },

  "requirements_contract": {
    "artifact": ".github/tasks/TASK-{NNN}/requirements.json",
    "schema": ".github/workflow/schemas/requirements-record.schema.json",
    "source_systems": ["github_issues", "jira", "linear", "azure_devops", "none"],
    "internal_source_requires_human_approval_kind": "requirements",
    "external_source_provenance_via_idp": true,
    "check_plan_enforces_token_overlap": true
  },

  "plan_contract": {
    "artifact": ".github/tasks/TASK-{NNN}/plan.json",
    "schema": ".github/workflow/schemas/plan-record.schema.json",
    "normal_planning_requires_graph_freshness": "fresh",
    "degraded_planning_requires_human_approval": true,
    "graph_usage_declaration_required": true,
    "graph_usage_statuses": ["used", "skipped-with-approval", "unavailable"],
    "graph_refs_max": 5,
    "graph_scope_required": true,
    "grill_gate_required": true,
    "intended_files_subset_of_grill_impacted": true,
    "verification_commands_subset_of_grill_steps": true,
    "approval_artifact_kind": "plan",
    "degraded_graph_approval_artifact_kind": "graph-degraded",
    "diagnosis_required_blocks_execution": true,
    "writes_active_task_to_state": true
  },

  "execute_contract": {
    "artifact": ".github/tasks/TASK-{NNN}/execution.json",
    "requires_approved_plan": true,
    "edits_limited_to_plan_intended_files": true,
    "out_of_scope_changes_require_deviation_approval": true,
    "scope_drift_approval_artifact_kind": "scope-drift",
    "memory_write_approval_artifact_kind": "memory-write",
    "governance_edit_approval_artifact_kind": "governance-edit",
    "governance_prefixes": [
      "AGENTS.md",
      ".github/copilot-instructions.md",
      ".github/instructions/",
      ".github/agents/",
      ".github/hooks/",
      ".github/skills/",
      ".github/workflow/"
    ],
    "memory_prefixes": [
      ".github/local-memory/",
      ".codex/memories/"
    ]
  },

  "verify_contract": {
    "draft_artifact": ".github/tasks/TASK-{NNN}/verification_draft.json",
    "receipt_artifact": ".github/tasks/TASK-{NNN}/verification_receipt.json",
    "draft_schema": ".github/workflow/schemas/verification-draft.schema.json",
    "receipt_schema": ".github/workflow/schemas/verification-receipt.schema.json",
    "verification_commands_locked_to_plan": true,
    "executor_witness_pattern": true,
    "shell_false_required": true,
    "draft_deleted_after_receipt_written": true,
    "review_fields_filled_by_human_after_witnessing": true,
    "graph_data_is_not_correctness_evidence": true,
    "clears_active_task_on_closeout": true
  },

  "local_memory_contract": {
    "path": ".github/local-memory/",
    "directories": ["inbox", "accepted", "rejected"],
    "candidate_schema": ".github/workflow/schemas/memory-candidate.schema.json",
    "validator": ".github/workflow/validators/check-memory",
    "writes_require_approval_kind": "memory-write",
    "normal_hooks_write_memory": false,
    "accepted_candidates_require_evidence": true,
    "rejected_candidates_are_audit_only": true
  },

  "evaluation_contract": {
    "command": "/evaluate",
    "maintainer_only": true,
    "evaluator": ".github/workflow/evaluators/evaluate-tasks",
    "output_pattern": ".github/evals/runs/EVAL-YYYYMMDD-HHMM/",
    "outputs": ["summary.json", "task-metrics.json", "findings.md"],
    "raw_prompts_included_by_default": false,
    "requires_network": false
  },

  "human_gates": [
    "approve_grill",
    "approve_plan",
    "approve_risky_tool_use",
    "approve_verification_review"
  ],
  "conditional_maintainer_gates": ["approve_workflow_improvement"],

  "safe_default_mode": {
    "requires_plugins": false,
    "requires_mcp": false,
    "requires_lsp": false,
    "requires_hooks": false,
    "requires_admin": false,
    "requires_third_party_python": false
  },

  "enterprise_pipeline": {
    "on_setup": [
      {
        "script": ".github/workflow/validators/check-setup",
        "args": []
      }
    ],
    "on_grill": [
      {
        "script": ".github/workflow/validators/check-grill",
        "args": [".github/tasks/{active_task}/grill.json"]
      }
    ],
    "on_planning": [
      {
        "script": ".github/workflow/validators/check-graph",
        "args": [".github/workflow/graph-record.json", ".github/tasks/{active_task}/plan.json"]
      },
      {
        "script": ".github/workflow/validators/check-plan",
        "args": [".github/tasks/{active_task}/plan.json"]
      },
      {
        "script": ".github/workflow/validators/check-state",
        "args": []
      }
    ],
    "on_execution": [
      {
        "script": ".github/workflow/validators/check-execution",
        "args": [".github/tasks/{active_task}/execution.json"]
      },
      {
        "script": ".github/workflow/validators/check-state",
        "args": []
      }
    ],
    "on_verification": [
      {
        "script": ".github/workflow/validators/check-verification",
        "args": [".github/tasks/{active_task}/verification_draft.json"]
      },
      {
        "script": ".github/workflow/validators/check-state",
        "args": []
      }
    ]
  }
}
