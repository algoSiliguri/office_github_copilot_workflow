{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "approval-record.schema.v1",
  "type": "object",
  "required": ["approval_id", "kind", "requested_by", "approved_by", "approved_at", "decision", "reason", "expires_at"],
  "properties": {
    "approval_id": { "type": "string", "pattern": "^APP-" },
    "kind": { "enum": ["plan", "graph-degraded", "scope-drift", "memory-write", "governance-edit"] },
    "requested_by": { "type": "string", "minLength": 1 },
    "approved_by": { "type": "string", "minLength": 1 },
    "approved_at": { "type": "string", "format": "date-time" },
    "decision": { "enum": ["approved", "rejected"] },
    "reason": { "type": "string", "minLength": 10 },
    "expires_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
