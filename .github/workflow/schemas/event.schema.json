{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event.schema.v1",
  "type": "object",
  "required": ["schema_version", "event_id", "task_id", "phase", "timestamp", "event_type", "tool_name", "target_files", "decision", "reason", "risk", "redacted"],
  "properties": {
    "schema_version": { "const": "event.schema.v1" },
    "event_id": { "type": "string" },
    "task_id": { "type": ["string", "null"] },
    "phase": { "enum": ["setup", "plan", "execute", "verify", "review", "evaluate", null] },
    "timestamp": { "type": "string" },
    "event_type": {
      "enum": [
        "session.started",
        "session.ended",
        "prompt.submitted",
        "tool.requested",
        "tool.allowed",
        "tool.denied",
        "tool.asked",
        "file.edit_attempt",
        "command.execution_attempt",
        "governance_file.edit_attempt",
        "verification.command_execution",
        "phase.transition",
        "hook.error"
      ]
    },
    "tool_name": { "type": "string" },
    "target_files": { "type": "array", "items": { "type": "string" } },
    "decision": { "enum": ["allow", "deny", "ask", "observe"] },
    "reason": { "type": "string" },
    "risk": { "enum": ["low", "medium", "high"] },
    "redacted": { "type": "boolean" },
    "session_id": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  }
}
