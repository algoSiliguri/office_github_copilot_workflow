{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "execution-record.schema.v1",
  "type": "object",
  "required": ["schema_version", "task_id", "created_at", "phase", "plan_ref", "approved_files", "modified_files", "status", "graph_refs", "command_refs", "checkpoints", "risky_tool_approvals", "deviations"],
  "properties": {
    "schema_version": { "const": "execution-record.schema.v1" },
    "task_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "phase": { "const": "execute" },
    "plan_ref": { "type": "string" },
    "approved_files": { "type": "array", "items": { "type": "string" } },
    "modified_files": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["completed", "blocked", "failed"] },
    "graph_refs": { "type": "array", "items": { "type": "string" } },
    "command_refs": { "type": "array", "items": { "type": "string" } },
    "checkpoints": { "type": "array" },
    "risky_tool_approvals": { "type": "array" },
    "deviations": { "type": "array" }
  }
}
