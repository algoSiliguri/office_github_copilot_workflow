{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graph-record.schema.v1",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "graph_dir",
    "graph_json",
    "graph_report",
    "manifest",
    "copilot_install_expected",
    "graph_status",
    "last_checked_at",
    "status",
    "generated_at",
    "repo_root",
    "git_commit",
    "branch",
    "graphify_manifest_path",
    "graph_output_exists",
    "approval",
    "notes"
  ],
  "properties": {
    "schema_version": { "const": "graph-record.schema.v1" },
    "provider": { "const": "graphify" },
    "graph_dir": { "const": "graphify-out" },
    "graph_json": { "const": "graphify-out/graph.json" },
    "graph_report": { "const": "graphify-out/GRAPH_REPORT.md" },
    "manifest": { "const": "graphify-out/manifest.json" },
    "copilot_install_expected": { "const": true },
    "graph_status": { "enum": ["fresh", "stale", "missing", "degraded-approved"] },
    "last_checked_at": { "type": ["string", "null"] },
    "status": { "enum": ["fresh", "stale", "missing", "degraded-approved"] },
    "generated_at": { "type": ["string", "null"] },
    "repo_root": { "type": "string" },
    "git_commit": { "type": ["string", "null"] },
    "branch": { "type": ["string", "null"] },
    "graphify_manifest_path": { "type": "string" },
    "graph_output_exists": {
      "type": "object",
      "required": ["graph_dir", "graph_json", "graph_report", "manifest"],
      "properties": {
        "graph_dir": { "type": "boolean" },
        "graph_json": { "type": "boolean" },
        "graph_report": { "type": "boolean" },
        "manifest": { "type": "boolean" }
      }
    },
    "approval": { "oneOf": [{ "$ref": "approval-record.schema.v1" }, { "type": "null" }] },
    "notes": { "type": "string" }
  }
}
