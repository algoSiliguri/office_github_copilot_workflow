{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "verification-record.schema.v1",
  "type": "object",
  "required": ["schema_version", "task_id", "phase", "plan_ref", "execution_ref", "verification_command", "command_refs", "result", "evidence_summary", "graph_refs", "degraded_verification"],
  "properties": {
    "schema_version": { "const": "verification-record.schema.v1" },
    "task_id": { "type": "string" },
    "phase": { "const": "verify" },
    "plan_ref": { "type": "string" },
    "execution_ref": { "type": "string" },
    "verification_command": { "type": "string" },
    "command_refs": { "type": "array", "items": { "type": "string" } },
    "result": { "enum": ["passed", "failed", "not_run"] },
    "evidence_summary": { "type": "string" },
    "graph_refs": { "type": "array", "items": { "type": "string" } },
    "degraded_verification": { "type": "object" }
  }
}
