#!/usr/bin/env python3
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

from approval_model import require_approved_kind, validate_approval
from path_policy import PathPolicy
from validator_core import load_json as _load_json, make_validator, require_iso8601

fail, require = make_validator("check-execution")


def load_json(path):
    return _load_json(path, fail)


_orchestration = load_json(Path(__file__).resolve().parent.parent / "orchestration.json")
_path_policy = PathPolicy(_orchestration)

if len(sys.argv) != 2:
    fail("usage: check-execution PATH")

path = Path(sys.argv[1])
with path.open(encoding="utf-8") as handle:
    record = json.load(handle)

required = [
    "schema_version",
    "task_id",
    "created_at",
    "phase",
    "plan_ref",
    "approved_files",
    "modified_files",
    "status",
    "graph_refs",
    "command_refs",
    "checkpoints",
    "risky_tool_approvals",
    "deviations",
    "approvals",
]
missing = [key for key in required if key not in record]
if missing:
    fail(f"missing required fields: {', '.join(missing)}")
require(record["schema_version"] == "execution-record.schema.v1", "wrong schema_version")
require_iso8601(record["created_at"], "created_at", fail)
require(record["phase"] == "execute", "phase must be execute")
require(record["status"] in {"completed", "blocked", "failed"}, "invalid status")
require(isinstance(record["approved_files"], list) and bool(record["approved_files"]), "approved_files must be a non-empty list")
require(isinstance(record["modified_files"], list), "modified_files must be a list")
require(isinstance(record["graph_refs"], list), "graph_refs must be a list")
require(isinstance(record["command_refs"], list), "command_refs must be a list")
require(isinstance(record["checkpoints"], list) and bool(record["checkpoints"]), "checkpoints must be a non-empty list")
require(isinstance(record["risky_tool_approvals"], list), "risky_tool_approvals must be a list")
require(isinstance(record["approvals"], list), "approvals must be a list")
for index, approval in enumerate(record["approvals"]):
    validate_approval(approval, None, f"approvals[{index}]", fail)

approved = set(record["approved_files"])
modified = set(record["modified_files"])
out_of_scope = sorted(modified - approved)
if out_of_scope:
    deviations = record["deviations"]
    require(deviations, f"out-of-scope modifications require deviations: {', '.join(out_of_scope)}")
    approved_drift = [
        item for item in deviations
        if item.get("type") == "out_of_scope_file"
    ]
    require(approved_drift, "out-of-scope modifications require explicit deviation records")
    require_approved_kind(record["approvals"], "scope-drift", "out-of-scope modifications", fail)

for approval in record["risky_tool_approvals"]:
    require(approval.get("decision") in {"approved", "denied"}, "risky tool approval must record approved or denied")
    require(bool(approval.get("category")), "risky tool approval must include category")


if any(_path_policy.is_governance(path) for path in modified):
    require_approved_kind(record["approvals"], "governance-edit", "governance edits", fail)

if any(_path_policy.is_memory(path) for path in modified):
    require_approved_kind(record["approvals"], "memory-write", "memory writes", fail)

risky_categories = {str(item.get("category", "")).replace("_", "-") for item in record["risky_tool_approvals"]}
if "governance-edit" in risky_categories or "workflow-governance-edits" in risky_categories:
    require_approved_kind(record["approvals"], "governance-edit", "governance risky tool use", fail)
if "memory-write" in risky_categories or "memory-writes" in risky_categories:
    require_approved_kind(record["approvals"], "memory-write", "memory risky tool use", fail)

print("check-execution: ok")
