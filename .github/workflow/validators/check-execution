#!/usr/bin/env python3
import json
import sys
from pathlib import Path


def fail(message):
    print(f"check-execution: FAIL: {message}", file=sys.stderr)
    sys.exit(1)


if len(sys.argv) != 2:
    fail("usage: check-execution PATH")

path = Path(sys.argv[1])
with path.open(encoding="utf-8") as handle:
    record = json.load(handle)

required = [
    "schema_version",
    "task_id",
    "phase",
    "plan_ref",
    "approved_files",
    "modified_files",
    "status",
    "deviations",
]
missing = [key for key in required if key not in record]
if missing:
    fail(f"missing required fields: {', '.join(missing)}")
if record["schema_version"] != "execution-record.schema.v1":
    fail("wrong schema_version")
if record["phase"] != "execute":
    fail("phase must be execute")
if record["status"] not in {"completed", "blocked", "failed"}:
    fail("invalid status")

approved = set(record["approved_files"])
modified = set(record["modified_files"])
out_of_scope = sorted(modified - approved)
if out_of_scope and not record["deviations"]:
    fail(f"out-of-scope modifications require deviations: {', '.join(out_of_scope)}")

print("check-execution: ok")
