#!/usr/bin/env python3
import argparse
import shutil
from pathlib import Path

from validator_core import make_validator

FIX_GRAPHIFY = "Install Graphify, then run: graphify"
FIX_COPILOT = "Run: graphify copilot install"

fail, require = make_validator("check-graphify-copilot")


def parse_args():
    parser = argparse.ArgumentParser(
        description="Check the local Graphify and Copilot Graphify setup without mutating user files."
    )
    parser.add_argument(
        "--repo-root",
        default=".",
        help="Repository root to inspect. Defaults to the current directory.",
    )
    parser.add_argument(
        "--home",
        default=str(Path.home()),
        help="Home directory to inspect for Copilot skill installation. Defaults to the current user's home.",
    )
    parser.add_argument(
        "--graphify-bin",
        default=None,
        help="Explicit Graphify executable path for fixtures or constrained shells.",
    )
    return parser.parse_args()


def graphify_command_exists(explicit):
    if explicit is not None:
        return Path(explicit).is_file()
    return shutil.which("graphify") is not None


def main():
    args = parse_args()
    repo_root = Path(args.repo_root).resolve()
    home = Path(args.home).expanduser().resolve()

    require(graphify_command_exists(args.graphify_bin), f"Graphify command was not found. {FIX_GRAPHIFY}")

    graph_dir = repo_root / "graphify-out"
    graph_report = graph_dir / "GRAPH_REPORT.md"
    graph_json = graph_dir / "graph.json"
    manifest = graph_dir / "manifest.json"
    require(graph_dir.is_dir(), f"missing graphify-out/. Run: graphify")
    require(graph_report.is_file(), f"missing graphify-out/GRAPH_REPORT.md. Run: graphify")
    require(graph_json.is_file(), f"missing graphify-out/graph.json. Run: graphify")
    require(manifest.is_file(), f"missing graphify-out/manifest.json. Run: graphify")

    copilot_skill = home / ".copilot" / "skills" / "graphify" / "SKILL.md"
    require(
        copilot_skill.is_file(),
        f"Copilot Graphify skill was not found at {copilot_skill}. {FIX_COPILOT}",
    )

    print("check-graphify-copilot: ok")


if __name__ == "__main__":
    main()
