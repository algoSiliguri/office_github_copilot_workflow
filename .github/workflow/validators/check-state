#!/usr/bin/env python3
import sys
from pathlib import Path

from validator_core import load_json as _load_json, make_validator

ROOT = Path.cwd()

fail, require = make_validator("check-state")


def load_json(path):
    return _load_json(path, fail)


def task_dirs(tasks_root):
    if not tasks_root.exists():
        return []
    return sorted(path for path in tasks_root.iterdir() if path.is_dir() and path.name.startswith("TASK-"))


def required_task_id(record, expected, path):
    require(record.get("task_id") == expected, f"{path} task_id must match folder name {expected}")


def plan_is_approved(plan):
    return plan.get("status") == "EXECUTION_READY" and plan.get("human_approval", {}).get("decision") == "approved"


def receipt_is_terminal(receipt):
    authorization = receipt.get("human_authorization", {})
    return authorization.get("status") in {"approved", "rejected"}


def task_is_closed(task_dir):
    receipt_path = task_dir / "verification_receipt.json"
    if not receipt_path.exists():
        return False
    return receipt_is_terminal(load_json(receipt_path))


def validate_task_folder(task_dir):
    task_id = task_dir.name
    grill_path = task_dir / "grill.json"
    plan_path = task_dir / "plan.json"
    execution_path = task_dir / "execution.json"
    receipt_path = task_dir / "verification_receipt.json"

    require(plan_path.exists(), f"{task_id} missing plan.json")
    plan = load_json(plan_path)
    required_task_id(plan, task_id, plan_path)

    if grill_path.exists():
        grill = load_json(grill_path)
        required_task_id(grill, task_id, grill_path)

    if execution_path.exists():
        execution = load_json(execution_path)
        required_task_id(execution, task_id, execution_path)
        require(plan_is_approved(plan), f"{task_id} cannot execute without an approved execution-ready plan")
        require(execution.get("plan_ref"), f"{task_id} execution must reference plan")

    if receipt_path.exists():
        require(execution_path.exists(), f"{task_id} cannot close without execution.json")
        receipt = load_json(receipt_path)
        required_task_id(receipt, task_id, receipt_path)
        require(receipt.get("schema_version") == "verification-receipt.schema.v2", f"{task_id} verification_receipt.json has wrong schema_version")

        auth = receipt.get("human_authorization", {})
        if auth.get("status") == "rejected":
            require(bool(auth.get("reason")), f"{task_id} rejected authorization requires a structured reason")

        approval = receipt.get("human_approval") or {}
        if approval.get("decision") == "rejected":
            require(bool(approval.get("reason")), f"{task_id} rejected human_approval requires a structured reason")

        scope_review = receipt.get("graph_scope_review", {})
        outside_files = scope_review.get("actual_files_outside_graph_scope", [])
        if outside_files:
            require(scope_review.get("notes", "").strip(), f"{task_id} modified files outside graph scope; graph_scope_review.notes is required")

    return task_is_closed(task_dir)


if len(sys.argv) not in {1, 3}:
    fail("usage: check-state [STATE_PATH TASKS_ROOT]")

if len(sys.argv) == 3:
    state_path = Path(sys.argv[1])
    tasks_root = Path(sys.argv[2])
else:
    state_path = ROOT / ".github/workflow/state.json"
    tasks_root = ROOT / ".github/tasks"

state = load_json(state_path)
require(state.get("schema_version") == "state.schema.v1", "state.json has wrong schema_version")
require("active_task" in state, "state.json missing active_task")
active_task = state.get("active_task")
require(active_task is None or isinstance(active_task, str), "active_task must be null or a task id")

dirs = task_dirs(tasks_root)
task_names = {path.name for path in dirs}
if active_task is not None:
    require(active_task in task_names, f"active_task points to missing task folder: {active_task}")

open_tasks = []
for task_dir in dirs:
    closed = validate_task_folder(task_dir)
    if not closed:
        open_tasks.append(task_dir.name)

require(len(open_tasks) <= 1, f"only one active task is allowed, found: {', '.join(open_tasks)}")
if open_tasks:
    require(active_task == open_tasks[0], f"active_task must match open task folder: {open_tasks[0]}")
else:
    require(active_task is None, "active_task must be null when no task is open")

print("check-state: ok")
