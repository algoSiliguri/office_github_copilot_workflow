#!/usr/bin/env python3
"""Executor-Witness for the verify phase (v2).

Reads verification_draft.json (AI semantic context), loads canonical plan.json
and execution.json via the refs in the draft, runs each locked command from
plan.verification_commands via subprocess.run(shell=False), captures the
kernel returncode, and — if all commands pass — writes verification_receipt.json
(machine-witnessed facts + AI semantic fields + pending review placeholders)
then deletes the draft.

check-state validates that the receipt's human_authorization is terminal after
the human fills in the review section.
"""
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

from approval_model import validate_approval
from evidence_policy import uses_graph_as_proof
from validator_core import load_json as _load_json, make_validator, require_iso8601

fail, require = make_validator("check-verification")


def load_json(path):
    return _load_json(path, fail)


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def load_ref(ref, label):
    path = Path(str(ref))
    require(path.exists(), f"{label} must reference an existing file: {ref}")
    return load_json(path)


if len(sys.argv) != 2:
    fail("usage: check-verification VERIFICATION_DRAFT_PATH")

draft_path = Path(sys.argv[1])
with draft_path.open(encoding="utf-8") as fh:
    draft = json.load(fh)

for key in [
    "schema_version", "task_id", "created_at", "phase",
    "plan_ref", "execution_ref",
    "evidence_summary", "graph_context_used", "graph_refs", "degraded_verification",
]:
    if key not in draft:
        fail(f"verification draft missing required field: {key}")

require(draft["schema_version"] == "verification-draft.schema.v2", "draft has wrong schema_version")
require_iso8601(draft["created_at"], "draft.created_at", fail)
require(draft["phase"] == "verify", "draft phase must be verify")
require(bool(draft["evidence_summary"]), "evidence_summary is required")
require(not uses_graph_as_proof(draft["evidence_summary"]), "Graphify may not be used as verification proof")
require(draft["graph_context_used"] in {True, False}, "graph_context_used must be boolean")
require(isinstance(draft["graph_refs"], list), "graph_refs must be a list")
if draft["graph_context_used"]:
    require(draft["graph_refs"], "graph_context_used=true requires graph_refs")

degraded = draft["degraded_verification"]
require(isinstance(degraded, dict) and "used" in degraded, "degraded_verification must be an object with 'used'")
if degraded.get("used"):
    require(bool(degraded.get("acknowledged_by")), "degraded verification requires acknowledged_by")

# Load canonical plan and execution via refs.
plan = load_ref(draft["plan_ref"], "draft.plan_ref")
execution = load_ref(draft["execution_ref"], "draft.execution_ref")

require(plan.get("task_id") == draft["task_id"], "plan.task_id must match draft.task_id")
require(execution.get("task_id") == draft["task_id"], "execution.task_id must match draft.task_id")

# Cross-validate scope: execution.modified_files must be within plan.intended_files or deviation-approved.
approved_files = set(execution.get("approved_files", []))
modified_files = set(execution.get("modified_files", []))
out_of_scope = modified_files - approved_files
if out_of_scope:
    deviation_files = {
        item.get("file")
        for item in execution.get("deviations", [])
        if isinstance(item, dict) and item.get("type") == "out_of_scope_file"
    }
    unapproved = sorted(out_of_scope - deviation_files)
    require(not unapproved, f"execution modified files outside approved scope without deviation records: {', '.join(unapproved)}")

# Read locked commands from the human-approved plan.
verification_commands = plan.get("verification_commands", [])
require(isinstance(verification_commands, list) and verification_commands, "plan.verification_commands must be a non-empty list")

# Executor-Witness: spawn each command, capture kernel returncode.
witnessed = []
for cmd in verification_commands:
    require(isinstance(cmd, list) and cmd, f"plan.verification_commands entry must be a non-empty array: {cmd}")
    executed_at = now_iso()
    result = subprocess.run(cmd, shell=False)
    exit_code = result.returncode
    witnessed.append({"command": cmd, "exit_code": exit_code, "executed_at": executed_at})
    if exit_code != 0:
        print(f"check-verification: FAIL: command {cmd} exited {exit_code}", file=sys.stderr)
        sys.exit(1)

# All commands passed — assemble receipt.
all_actual_files = sorted(modified_files)
plan_scope = plan.get("graph_scope", {})
graph_in_scope = set(plan_scope.get("in_scope_files", []))
actual_set = set(all_actual_files)
inside = sorted(actual_set & graph_in_scope)
outside = sorted(actual_set - graph_in_scope)

receipt = {
    "schema_version": "verification-receipt.schema.v2",
    "task_id": draft["task_id"],
    "created_at": now_iso(),
    "phase": "verify",
    "plan_ref": draft["plan_ref"],
    "execution_ref": draft["execution_ref"],
    "witness": {
        "commands": witnessed,
        "all_passed": True,
        "witnessed_at": now_iso(),
    },
    "evidence_summary": draft["evidence_summary"],
    "graph_context_used": draft["graph_context_used"],
    "graph_refs": draft["graph_refs"],
    "degraded_verification": draft["degraded_verification"],
    # Review section — filled in by the agent + human after witnessing.
    "approved_files": sorted(approved_files),
    "actual_files": all_actual_files,
    "scope_drift": [],
    "findings": [],
    "assumptions": [],
    "deviations": list(execution.get("deviations", [])),
    "graph_scope_review": {
        "actual_files_inside_graph_scope": inside,
        "actual_files_outside_graph_scope": outside,
        "requires_scope_drift_approval": bool(outside),
        "notes": "",
    },
    "human_authorization": {"status": "pending", "reason": None},
    "human_approval": None,
    "approvals": [],
}

receipt_path = draft_path.parent / "verification_receipt.json"
with receipt_path.open("w", encoding="utf-8") as fh:
    json.dump(receipt, fh, indent=2)
    fh.write("\n")

draft_path.unlink()

print(f"check-verification: witness complete — receipt written to {receipt_path}")
