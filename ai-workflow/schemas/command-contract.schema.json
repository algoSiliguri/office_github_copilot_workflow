{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Command Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command_contract_id",
    "stable_alias",
    "contract_version",
    "output_artifacts",
    "required_policies",
    "required_validators",
    "authority",
    "semantics"
  ],
  "properties": {
    "command_contract_id": {
      "type": "string",
      "minLength": 1
    },
    "stable_alias": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "input_artifacts": {
      "type": "array"
    },
    "output_artifacts": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "schema",
          "required"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "schema": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "required_policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_validators": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before",
        "after"
      ],
      "properties": {
        "before": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "after": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_create",
        "may_modify",
        "may_read",
        "forbidden"
      ],
      "properties": {
        "may_create": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "may_modify": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "may_read": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
