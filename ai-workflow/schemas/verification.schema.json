{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "task_id",
    "primary_surface",
    "plan_ref",
    "execution_ref",
    "changed_files",
    "verification_command",
    "verification_command_run",
    "command_output",
    "evidence",
    "status",
    "validated_under"
  ],
  "properties": {
    "artifact_type": { "const": "VerificationRecord" },
    "schema_version": { "const": "verification.schema.v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "primary_surface": { "enum": ["copilot_plugin", "copilot_cli"] },
    "secondary_surfaces_allowed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plan_ref": { "type": "string", "minLength": 1 },
    "execution_ref": { "type": "string", "minLength": 1 },
    "changed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_command": { "type": "string", "minLength": 1 },
    "verification_command_run": { "type": "string", "minLength": 1 },
    "command_output": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": { "enum": ["VERIFIED", "VERIFIED_WITH_DEGRADATION", "FAILED", "BLOCKED"] },
    "degraded_reason": { "type": ["string", "null"] },
    "human_acknowledgment": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["status", "reviewer", "reason"],
      "properties": {
        "status": { "enum": ["pending", "approved", "rejected"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "validated_under": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_manifest_version",
        "workflow_contract_version",
        "command_contract_id",
        "command_contract_version",
        "artifact_schema",
        "config_instruction_version"
      ],
      "properties": {
        "workflow_manifest_version": { "type": "integer", "const": 1 },
        "workflow_contract_version": { "type": "integer", "const": 1 },
        "command_contract_id": { "type": "string", "const": "verify.v1" },
        "command_contract_version": { "type": "integer", "const": 1 },
        "artifact_schema": { "type": "string", "const": "verification.schema.v1" },
        "config_instruction_version": { "type": "string", "const": "v1" }
      }
    }
  }
}
