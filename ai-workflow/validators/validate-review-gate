#!/usr/bin/env python3
import sys
from pathlib import Path

import yaml


def fail(reason: str) -> int:
    print(f"FAIL: {reason}")
    return 1


def require(condition: bool, reason: str):
    if not condition:
        raise ValueError(reason)


def load_yaml(path: Path):
    data = yaml.safe_load(path.read_text())
    require(isinstance(data, dict), f"{path} must contain a mapping")
    return data


def main() -> int:
    if len(sys.argv) != 2:
        return fail("usage: validate-review-gate <artifact-path>")

    try:
        artifact = load_yaml(Path(sys.argv[1]))
        require(artifact.get("schema_version") == "review.schema.v1", "validate-review-gate only accepts review.schema.v1 artifacts")

        plan = load_yaml(Path(artifact["plan_ref"]))
        execution = load_yaml(Path(artifact["execution_ref"]))
        verification = load_yaml(Path(artifact["verification_ref"]))

        actual_from_execution = execution["actual_changes"]["files_touched"]
        require(artifact["actual_changed_files"] == actual_from_execution, "actual_changed_files must exactly match execution.actual_changes.files_touched")

        scope_paths = {entry["path"] for entry in plan["files_in_scope"]}
        expected_violations = [path for path in actual_from_execution if path not in scope_paths]
        require(artifact["scope_violations"] == expected_violations, "scope_violations must exactly reflect changed files outside plan scope")
        require(artifact["scope_match"] == (len(expected_violations) == 0), "scope_match must agree with scope_violations")

        verification_status = verification["status"]
        if verification_status not in {"VERIFIED", "VERIFIED_WITH_DEGRADATION"}:
            require(artifact["status"] in {"FAIL", "BLOCKED"}, "review cannot PASS when verification is not verified")

        status = artifact["status"]
        if status in {"PASS", "PASS_WITH_DEGRADATION"}:
            require(artifact["scope_match"] is True, f"{status} requires scope_match=true")
            human_auth = artifact.get("human_authorization")
            require(isinstance(human_auth, dict), f"{status} requires human_authorization")
            require(human_auth.get("status") == "approved", f"{status} requires approved human_authorization")
            require(isinstance(human_auth.get("reviewer"), str) and human_auth["reviewer"].strip(), "human_authorization.reviewer must be set")
        if status == "PASS_WITH_DEGRADATION":
            require(isinstance(artifact.get("degraded_reason"), str) and artifact["degraded_reason"].strip(), "PASS_WITH_DEGRADATION requires degraded_reason")

        print("PASS")
        return 0
    except ValueError as exc:
        return fail(str(exc))
    except Exception as exc:
        return fail(f"unexpected validation error: {exc}")


if __name__ == "__main__":
    sys.exit(main())
